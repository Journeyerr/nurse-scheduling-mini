<!--pages/statistics/statistics.wxml-->
<view class="stats-container">
  <!-- 月份选择 -->
  <view class="month-selector card">
    <view class="selector-btn" bindtap="prevMonth">
      <text class="arrow">‹</text>
    </view>
    <text class="current-month">{{currentYear}}年{{currentMonth}}月</text>
    <view class="selector-btn" bindtap="nextMonth">
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 个人统计（护士） -->
  <view class="stats-section card" wx:if="{{!isCreator}}">
    <view class="section-title">我的排班统计</view>
    <view class="stats-grid">
      <view class="stats-item">
        <text class="stats-value">{{myStats.totalDays}}</text>
        <text class="stats-label">排班天数</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{myStats.restDays}}</text>
        <text class="stats-label">休息天数</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{myStats.totalHours}}</text>
        <text class="stats-label">总工时</text>
      </view>
    </view>
    
    <view class="stats-detail">
      <view class="detail-title">班次详情</view>
      <view class="detail-list">
        <view class="detail-item" wx:for="{{myStats.shiftDetails}}" wx:key="name">
          <view class="detail-color" style="background-color: {{item.color}}"></view>
          <text class="detail-name">{{item.name}}</text>
          <text class="detail-count">{{item.count}}次</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 全员统计（护士长） -->
  <view class="stats-section card" wx:if="{{isCreator}}">
    <!-- 我的统计横幅 -->
    <view class="my-stats-banner">
      <view class="banner-item">
        <text class="banner-label">排班数</text>
        <text class="banner-value">{{currentUserStats.totalDays}}</text>
      </view>
      <view class="banner-item">
        <text class="banner-label">休息数</text>
        <text class="banner-value">{{currentUserStats.restDays}}</text>
      </view>
      <view class="banner-item">
        <text class="banner-label">总工时</text>
        <text class="banner-value">{{currentUserStats.totalHours}}h</text>
      </view>
    </view>


    <!-- 成员筛选 -->
    <view class="filter-section">
      <view class="picker-btn" bindtap="showPicker">
        <text>{{selectedMemberName}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </view>
    
    <view class="stats-grid" wx:if="{{selectedMemberId === 'all'}}">
      <view class="stats-item">
        <text class="stats-value">{{deptStats.totalSchedules}}</text>
        <text class="stats-label">排班总数</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{deptStats.totalRestSchedules}}</text>
        <text class="stats-label">休息数</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{deptStats.totalHours}}h</text>
        <text class="stats-label">总工时</text>
      </view>
    </view>
    
    <view class="stats-grid" wx:else>
      <view class="stats-item">
        <text class="stats-value">{{memberStats.totalDays}}</text>
        <text class="stats-label">排班天数</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{memberStats.restDays}}</text>
        <text class="stats-label">休息天数</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{memberStats.totalHours}}</text>
        <text class="stats-label">总工时</text>
      </view>
    </view>
    
    <!-- 成员排班排行 -->
    <view class="rank-section">
      <view class="detail-title" wx:if="{{selectedMemberId === 'all'}}">成员排行（共{{rankList.length}}人）</view>
      <view class="detail-title" wx:else>{{selectedMemberName}}</view>
      <view class="rank-list">
        <view class="rank-item" wx:for="{{rankList}}" wx:key="id">
          <view class="rank-left">
            <view class="rank-medal rank-medal-{{item.rankIndex < 3 ? (item.rankIndex + 1) : 'default'}}">
              <text class="rank-number">{{item.rankIndex + 1}}</text>
            </view>
            <text class="rank-name">{{item.name}}</text>
          </view>
          <view class="rank-right">
            <view class="rank-data-item">
              <text class="rank-data-label">排班</text>
              <text class="rank-data-value">{{item.scheduleCount}}</text>
            </view>
            <view class="rank-data-divider"></view>
            <view class="rank-data-item">
              <text class="rank-data-label">休息</text>
              <text class="rank-data-value">{{item.restCount}}</text>
            </view>
            <view class="rank-data-divider"></view>
            <view class="rank-data-item">
              <text class="rank-data-label">工时</text>
              <text class="rank-data-value">{{item.totalHours}}h</text>
            </view>
          </view>
        </view>

        <!-- 合计行（仅全部成员时显示） -->
        <view class="rank-item rank-total-row" wx:if="{{selectedMemberId === 'all'}}">
          <view class="rank-left">
            <text class="rank-name rank-total-label">合计</text>
          </view>
          <view class="rank-right">
            <view class="rank-data-item">
              <text class="rank-data-value rank-total-value">{{totalSummary.totalSchedules}}</text>
            </view>
            <view class="rank-data-divider"></view>
            <view class="rank-data-item">
              <text class="rank-data-value rank-total-value">{{totalSummary.totalRestSchedules}}</text>
            </view>
            <view class="rank-data-divider"></view>
            <view class="rank-data-item">
              <text class="rank-data-value rank-total-value">{{totalSummary.totalHours}}h</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 成员选择弹窗 -->
<view class="picker-mask" wx:if="{{showMemberPicker}}" bindtap="hidePicker" catchtouchmove="stopPropagation">
  <view class="picker-popup" catchtap="stopPropagation" catchtouchmove="stopPropagation">
    <view class="picker-header">
      <text class="picker-title">选择成员</text>
      <text class="picker-close" bindtap="hidePicker">×</text>
    </view>
    <scroll-view scroll-y class="picker-list">
      <view
        class="picker-item {{item.id === selectedMemberId ? 'active' : ''}}"
        wx:for="{{memberOptions}}"
        wx:key="id"
        bindtap="onMemberChange"
        data-id="{{item.id}}"
      >
        <text class="picker-item-text">{{item.name}}</text>
        <text class="picker-check" wx:if="{{item.id === selectedMemberId}}">✓</text>
      </view>
    </scroll-view>
  </view>
</view>
