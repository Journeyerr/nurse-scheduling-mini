<!--pages/work-hours/work-hours.wxml-->
<view class="stats-container">
  <!-- 月份选择 -->
  <view class="month-selector card">
    <view class="selector-btn" bindtap="prevMonth">
      <text class="arrow">‹</text>
    </view>
    <text class="current-month">{{currentYear}}年{{currentMonth}}月</text>
    <view class="selector-btn" bindtap="nextMonth">
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 个人统计（护士） -->
  <view class="stats-section card" wx:if="{{!isLeader}}">
    <view class="section-title">我的排班统计</view>
    <view class="stats-grid">
      <view class="stats-item">
        <text class="stats-value">{{myStats.totalDays}}</text>
        <text class="stats-label">排班天数</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{myStats.totalHours}}</text>
        <text class="stats-label">总工时</text>
      </view>
      <view class="stats-item balance-saved" wx:if="{{myStats.balanceDays > 0}}">
        <text class="stats-value">+{{myStats.balanceDays}}</text>
        <text class="stats-label">欠存</text>
      </view>
      <view class="stats-item balance-owed" wx:elif="{{myStats.balanceDays < 0}}">
        <text class="stats-value">{{myStats.balanceDays}}</text>
        <text class="stats-label">欠存</text>
      </view>
      <view class="stats-item" wx:else>
        <text class="stats-value stats-value-gray">0</text>
        <text class="stats-label">欠存</text>
      </view>
    </view>
    
    <view class="stats-detail">
      <view class="detail-title">班次详情</view>
      <!-- 表头 -->
      <view class="shift-table-header">
        <text class="shift-col-name">班次</text>
        <view class="shift-col-right">
          <text class="shift-col-count">次数</text>
          <text class="shift-col-hours">工时</text>
          <text class="shift-col-hours" wx:if="{{showCoeff}}">系数和</text>
        </view>
      </view>
      <!-- 班次行 -->
      <view class="shift-table-row" wx:for="{{myStats.shiftDetails}}" wx:key="name">
        <view class="shift-row-left">
          <view class="detail-color" style="background-color: {{item.color}}"></view>
          <text class="detail-name">{{item.name}}</text>
        </view>
        <view class="shift-row-right">
          <text class="shift-count-val">{{item.count}}</text>
          <text class="shift-hours-val">{{item.hours || 0}}h</text>
          <text class="shift-coeff-val" wx:if="{{showCoeff}}">{{item.coefficientSum || 0}}</text>
        </view>
      </view>
      <!-- 系数和开关 -->
      <view class="coeff-toggle" bindtap="toggleShowCoeff">
        <text>{{showCoeff ? '隐藏系数和' : '显示系数和'}}</text>
      </view>
    </view>
  </view>

  <!-- 全员统计（护士长/管理员） -->
  <view class="stats-section card" wx:if="{{isLeader}}">
    <!-- 我的统计横幅 -->
    <view class="my-stats-banner">
      <view class="banner-item">
        <text class="banner-label">排班数</text>
        <text class="banner-value">{{currentUserStats.totalDays}}</text>
      </view>
      <view class="banner-item">
        <text class="banner-label">总工时</text>
        <text class="banner-value">{{currentUserStats.totalHours}}h</text>
      </view>
      <view class="banner-item banner-saved" wx:if="{{currentUserStats.balanceDays > 0}}">
        <text class="banner-label">欠存数</text>
        <text class="banner-value">+{{currentUserStats.balanceDays}}</text>
      </view>
      <view class="banner-item banner-owed" wx:elif="{{currentUserStats.balanceDays < 0}}">
        <text class="banner-label">欠存数</text>
        <text class="banner-value">{{currentUserStats.balanceDays}}</text>
      </view>
      <view class="banner-item" wx:else>
        <text class="banner-label">欠存数</text>
        <text class="banner-value banner-value-gray">0</text>
      </view>
    </view>


    <!-- 成员排班排行 -->
    <view class="rank-section">
      <view class="rank-header" bindtap="showPicker">
        <text wx:if="{{selectedMemberIds.length === 0}}">全部成员（{{rankList.length}}）</text>
        <text wx:elif="{{selectedMemberIds.length === 1}}">{{rankList[0].name}}</text>
        <text wx:else>已选{{selectedMemberIds.length}}人</text>
        <text class="picker-arrow">▼</text>
      </view>
      <view class="rank-list">
        <view class="rank-item" wx:for="{{rankList}}" wx:key="id">
          <view class="rank-left">
            <view class="rank-medal rank-medal-{{item.rankIndex < 3 ? (item.rankIndex + 1) : 'default'}}">
              <text class="rank-number">{{item.rankIndex + 1}}</text>
            </view>
            <text class="rank-name">{{item.name}}</text>
          </view>
          <view class="rank-right">
            <view class="rank-data-item">
              <text class="rank-data-label">排班</text>
              <text class="rank-data-value">{{item.scheduleCount}}</text>
            </view>
            <view class="rank-data-divider"></view>
            <view class="rank-data-item">
              <text class="rank-data-label">工时</text>
              <text class="rank-data-value">{{item.totalHours}}h</text>
            </view>
            <view class="rank-data-divider"></view>
            <view class="rank-data-item rank-saved" wx:if="{{item.balanceDays > 0}}">
              <text class="rank-data-label">欠存</text>
              <text class="rank-data-value">+{{item.balanceDays}}</text>
            </view>
            <view class="rank-data-item rank-owed" wx:elif="{{item.balanceDays < 0}}">
              <text class="rank-data-label">欠存</text>
              <text class="rank-data-value">{{item.balanceDays}}</text>
            </view>
            <view class="rank-data-item" wx:else>
              <text class="rank-data-label">欠存</text>
              <text class="rank-data-value">0</text>
            </view>
          </view>
        </view>

        <!-- 合计行 -->
        <view class="rank-item rank-total-row">
          <view class="rank-left">
            <text class="rank-name rank-total-label">合计</text>
          </view>
          <view class="rank-right">
            <view class="rank-data-item">
              <text class="rank-data-label">排班</text>
              <text class="rank-data-value rank-total-value">{{totalSummary.totalSchedules}}</text>
            </view>
            <view class="rank-data-divider"></view>
            <view class="rank-data-item">
              <text class="rank-data-label">工时</text>
              <text class="rank-data-value rank-total-value">{{totalSummary.totalHours}}h</text>
            </view>
            <view class="rank-data-divider"></view>
            <view class="rank-data-item">
              <text class="rank-data-label">欠存</text>
              <text class="rank-data-value rank-total-value">-</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 班次图例（普通护士可见） -->
  <view class="legend-section card" wx:if="{{!isLeader}}">
    <view class="legend-list">
      <view class="legend-item" wx:for="{{shiftList}}" wx:key="id">
        <view class="legend-color" style="background-color: {{item.color}}"></view>
        <text class="legend-text">{{item.code}}: {{item.name}}（×{{item.coefficient || 1.0}}）</text>
      </view>
    </view>
  </view>

</view>

<!-- 成员选择弹窗 -->
<view class="picker-mask" wx:if="{{showMemberPicker}}" bindtap="hidePicker" catchtouchmove="stopPropagation">
  <view class="picker-popup" catchtap="stopPropagation" catchtouchmove="stopPropagation">
    <view class="picker-header">
      <text class="picker-title">选择成员</text>
      <view class="picker-header-right">
        <text class="picker-action-btn" bindtap="toggleSelectAll">
          <text wx:if="{{selectedMemberIds.length === memberOptions.length && memberOptions.length > 0}}">取消全选</text>
          <text wx:else>全选</text>
        </text>
        <text class="picker-action-count">已选{{selectedMemberIds.length}}人</text>
        <text class="picker-close" bindtap="hidePicker">×</text>
      </view>
    </view>
    <scroll-view scroll-y class="picker-list">
      <view
        class="picker-item {{selectedMemberMap[item.id] ? 'active' : ''}}"
        wx:for="{{memberOptions}}"
        wx:key="id"
        bindtap="onMemberChange"
        data-id="{{item.id}}"
      >
        <view class="picker-checkbox {{selectedMemberMap[item.id] ? 'checked' : ''}}">
          <text class="picker-check-icon" wx:if="{{selectedMemberMap[item.id]}}">✓</text>
        </view>
        <text class="picker-item-text">{{item.name}}</text>
      </view>
    </scroll-view>
    <view class="picker-footer">
      <view class="picker-confirm-btn" bindtap="confirmMemberSelection">确定</view>
    </view>
  </view>
</view>
