/* pages/statistics/statistics.wxss */

.stats-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 20rpx;
}

/* 月份选择 */
.month-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  margin-bottom: 20rpx;
}

.selector-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow {
  font-size: 40rpx;
  color: #4A90D9;
}

.current-month {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 统计区域 */
.stats-section {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 我的统计横幅 */
.my-stats-banner {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.banner-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 12rpx;
  margin: 0 10rpx;
}

.banner-item:first-child {
  margin-left: 0;
}

.banner-item:last-child {
  margin-right: 0;
}

.banner-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.banner-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90D9;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.stats-grid {
  display: flex;
  margin-bottom: 30rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  margin: 0 10rpx;
}

.stats-item:first-child {
  margin-left: 0;
}

.stats-item:last-child {
  margin-right: 0;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90D9;
  margin-bottom: 10rpx;
}

.stats-value-gray {
  color: #999;
}

/* stats-grid 中的存班/欠班颜色 */
.balance-saved .stats-value {
  color: #E8380D;
}

.balance-owed .stats-value {
  color: #4A90D9;
}

/* 存班/欠班统计 */
.balance-grid {
  display: flex;
  margin-bottom: 20rpx;
}

.balance-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  margin: 0 10rpx;
  background: #F8F9FA;
}

.balance-item:first-child {
  margin-left: 0;
}

.balance-item:last-child {
  margin-right: 0;
}

.balance-value {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.balance-label {
  font-size: 22rpx;
  color: #999;
}

.balance-saved .balance-value {
  color: #E8380D;
}

.balance-owed .balance-value {
  color: #4A90D9;
}

.balance-even .balance-value {
  color: #999;
}

/* 护士长横幅中的存班/欠班 */
.banner-saved .banner-value {
  color: #E8380D !important;
}

.banner-owed .banner-value {
  color: #4A90D9 !important;
}

.banner-value-gray {
  color: #999 !important;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
}

/* 排行标题（含筛选下拉） */
.rank-header {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background: #F8F9FA;
  border-radius: 8rpx;
}

.rank-header .picker-arrow {
  margin-left: 10rpx;
  font-size: 20rpx;
  color: #999;
}

/* 详情列表 */
.stats-detail {
  padding-top: 30rpx;
  border-top: 1rpx solid #F0F0F0;
}

/* 班次详情表格 */
.shift-table-header,
.shift-table-row {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #F5F5F5;
}

.shift-table-header {
  font-size: 24rpx;
  color: #999;
  font-weight: bold;
  background: #FAFAFA;
  border-radius: 8rpx 8rpx 0 0;
}

.shift-row-left,
.shift-col-name {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.shift-row-right,
.shift-col-right {
  display: flex;
  flex-shrink: 0;
}

/* 每列统一宽度，表头和数据行对齐 */
.shift-col-count,
.shift-col-hours,
.shift-col-coeff,
.shift-count-val,
.shift-hours-val,
.shift-coeff-val {
  width: 110rpx;
  text-align: center;
  flex-shrink: 0;
}

.shift-col-coeff,
.shift-coeff-val {
  color: #4A90D9;
}

.shift-table-header .shift-col-count,
.shift-table-header .shift-col-hours,
.shift-table-header .shift-col-coeff {
  font-size: 24rpx;
  color: #999;
  font-weight: bold;
}

.shift-table-header .shift-col-coeff {
  color: #4A90D9;
}

.shift-count-val {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.shift-hours-val {
  font-size: 30rpx;
  color: #4A90D9;
  font-weight: bold;
}

.shift-coeff-val {
  font-size: 30rpx;
  color: #4A90D9;
  font-weight: bold;
}

.shift-coeff-val {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: bold;
}

/* 系数和开关 */
.coeff-toggle {
  text-align: center;
  padding: 16rpx 0 4rpx;
  font-size: 24rpx;
  color: #4A90D9;
}

.detail-title {
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-item {
  display: flex;
  align-items: center;
}

.detail-color {
  width: 12rpx;
  height: 40rpx;
  border-radius: 6rpx;
  margin-right: 20rpx;
}

.detail-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.detail-count {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: bold;
}

/* 排行列表 */
.rank-section {
  padding-top: 30rpx;
  border-top: 1rpx solid #F0F0F0;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #F0F0F0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.rank-left {
  display: flex;
  align-items: center;
}

.rank-medal {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.rank-medal-1 {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.3);
}

.rank-medal-2 {
  background: linear-gradient(135deg, #C0C0C0 0%, #A9A9A9 100%);
  box-shadow: 0 4rpx 12rpx rgba(192, 192, 192, 0.3);
}

.rank-medal-3 {
  background: linear-gradient(135deg, #CD7F32 0%, #B8860B 100%);
  box-shadow: 0 4rpx 12rpx rgba(205, 127, 50, 0.3);
}

.rank-medal-default {
  background: #F5F5F5;
}

.rank-number {
  font-size: 25rpx;
  font-weight: bold;
  color: #fff;
}

.rank-medal-default .rank-number {
  color: #999;
}

.rank-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.rank-right {
  display: flex;
  align-items: stretch;
}

.rank-data-item {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 0 16rpx;
  min-width: 80rpx;
}

.rank-data-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.rank-data-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A90D9;
}

/* 排行中的存班/欠班 */
.rank-saved .rank-data-value {
  color: #E8380D;
}

.rank-owed .rank-data-value {
  color: #4A90D9;
}

.rank-data-divider {
  width: 1rpx;
  align-self: center;
  height: 50rpx;
  background: #E0E0E0;
}

/* 合计行 */
.rank-total-row {
  background: linear-gradient(135deg, #F0F7FF 0%, #E8F4FD 100%);
  border-color: #C5DDF0;
}

.rank-total-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #4A90D9 !important;
}

.rank-total-value {
  color: #4A90D9 !important;
}

/* 成员选择弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.picker-popup {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.picker-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 10rpx;
}

/* 多选操作 */
.picker-action-btn {
  font-size: 26rpx;
  color: #4A90D9;
}

.picker-action-count {
  font-size: 24rpx;
  color: #999;
}

.picker-list {
  flex: 1;
  max-height: 50vh;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.picker-item:active {
  background: #F8F9FA;
}

.picker-item.active {
  background: #F0F7FF;
}

/* 复选框 */
.picker-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2rpx solid #D0D0D0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  transition: all 0.2s;
}

.picker-checkbox.checked {
  background: #4A90D9;
  border-color: #4A90D9;
}

.picker-check-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.picker-item-text {
  font-size: 30rpx;
  color: #333;
}

.picker-item.active .picker-item-text {
  color: #4A90D9;
  font-weight: 500;
}

/* 确认按钮 */
.picker-footer {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F0F0;
}

.picker-confirm-btn {
  background: #4A90D9;
  color: #fff;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.picker-confirm-btn:active {
  opacity: 0.85;
}

/* 班次图例 */
.legend-section {
  margin-top: 20rpx;
  padding: 24rpx 30rpx;
}

.legend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-color {
  width: 40rpx;
  height: 24rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.legend-text {
  font-size: 24rpx;
  color: #666;
}
