/* pages/approval/approval.wxss */

.approval-container {
  min-height: 100vh;
  background: #F5F7FA;
}

/* 页面标题 */
.page-header {
  background: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #F0F0F0;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.pending-badge {
  background: #E74C3C;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 列表区域 */
.list-section {
  padding: 20rpx;
}

.approval-item {
  position: relative;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  transition: opacity 0.3s, filter 0.3s;
}

/* 已处理卡片置灰 */
.approval-item.processed {
  opacity: 0.5;
  filter: saturate(0.2);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-right: 100rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.type-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.type-badge.schedule {
  background: #E3F2FD;
  color: #1976D2;
}

.type-badge.swap {
  background: #F3E5F5;
  color: #9848da;
}

/* 卡片主体 */
.card-body {
  margin-bottom: 0;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 8rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 80rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.swap-left {
  max-width: 200rpx;
}

.swap-right {
  margin-left: 70rpx;
  max-width: 200rpx;
}

.swap-icon {
  font-size: 28rpx;
  color: #4A90D9;
  width: 40rpx;
  text-align: center;
  flex-shrink: 0;
}

.submit-time {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 200rpx);
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 盖章样式 */
.stamp {
  position: absolute;
  top: -20rpx;
  right: -25rpx;
  width: 105rpx;
  height: 105rpx;
  border-radius: 50%;
  border: 6rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(-15deg);
  opacity: 0.85;
  z-index: 10;
}

.stamp.pending {
  border-color: #FFA000;
  background: rgba(255, 160, 0, 0.08);
}

.stamp.approved {
  border-color: #43A047;
  background: rgba(67, 160, 71, 0.08);
}

.stamp.rejected {
  border-color: #E74C3C;
  background: rgba(231, 76, 60, 0.08);
}

.stamp-text {
  font-size: 22rpx;
  font-weight: bold;
}

.stamp.pending .stamp-text {
  color: #FFA000;
}

.stamp.approved .stamp-text {
  color: #43A047;
}

.stamp.rejected .stamp-text {
  color: #E74C3C;
}

/* 详情弹窗 */
.bottom-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.bottom-modal-mask.show {
  visibility: visible;
  opacity: 1;
}

.bottom-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 67vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.bottom-modal-mask.show .bottom-modal {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

/* 详情头部 */
.detail-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.detail-user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 详情区域 */
.detail-section {
  margin-bottom: 30rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 20rpx;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

/* 换班详情行样式 */
.swap-detail-row {
  align-items: center;
}

.swap-detail-left {
  width: 180rpx;
  flex: none;
}

.swap-detail-right {
  width: 220rpx;
  margin-left: 40rpx;
  flex: none;
}

.swap-detail-icon {
  font-size: 32rpx;
  color: #4A90D9;
  width: 50rpx;
  text-align: center;
  flex-shrink: 0;
  margin: 0 12rpx;
}

/* 审批区域 */
.approval-section {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.approval-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.approval-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #F8F9FA;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.textarea-placeholder {
  color: #BBB;
}

/* 审批按钮 */
.approval-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  padding-bottom: 30rpx;
}

.btn-reject {
  flex: 1;
  background: #fff;
  color: #E74C3C;
  border: 2rpx solid #E74C3C;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 8rpx;
}

.btn-approve {
  flex: 1;
  background: #4A90D9;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 8rpx;
  border: none;
}
