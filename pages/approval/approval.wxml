<!--pages/approval/approval.wxml-->
<view class="approval-container">
  <!-- 标题 -->
  <view class="page-header">
    <text class="page-title">申请审批</text>
    <view class="pending-badge" wx:if="{{expectPending > 0}}">{{expectPending}}条待审批</view>
  </view>

  <!-- 申请列表 -->
  <view class="list-section">
    <view class="approval-item card {{item.status !== 'pending' ? 'processed' : ''}}" wx:for="{{expectList}}" wx:key="id" bindtap="showDetail" data-index="{{index}}">
      <!-- 盖章样式的审批状态 -->
      <view class="stamp {{item.status}}">
        <text class="stamp-text">{{item.statusName}}</text>
      </view>

      <!-- 卡片头部 -->
      <view class="card-header">
        <text class="user-name">{{item.userName}}</text>
        <text class="type-badge {{item.type}}">{{item.typeName}}</text>
      </view>

      <!-- 期望排班类型 -->
      <block wx:if="{{item.type === 'schedule'}}">
        <view class="card-body">
          <view class="info-row">
            <text class="info-label">日期：</text>
            <text class="info-value">{{item.startDate}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">班次：</text>
            <text class="info-value">{{item.shiftCode ? item.shiftCode + '-' : ''}}{{item.shiftName || '无'}}</text>
          </view>
        </view>
        <view class="card-footer">
          <text class="submit-time">{{item.createTime}}</text>
        </view>
      </block>

      <!-- 换班类型 -->
      <block wx:if="{{item.type === 'swap'}}">
        <view class="card-body">
          <view class="info-row">
            <text class="info-label">日期：</text>
            <text class="info-value swap-left">{{item.startDate}}</text>
            <text class="swap-icon">⇄</text>
            <text class="info-value swap-right">{{item.targetDate}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">对象：</text>
            <text class="info-value swap-left">{{item.userName}}</text>
            <text class="swap-icon">⇄</text>
            <text class="info-value swap-right">{{item.targetUserName}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">班次：</text>
            <text class="info-value swap-left">{{item.myShiftName || '无'}}</text>
            <text class="swap-icon">⇄</text>
            <text class="info-value swap-right">{{item.targetShiftName || '无'}}</text>
          </view>
        </view>
        <view class="card-footer">
          <text class="submit-time">{{item.createTime}}</text>
        </view>
      </block>
    </view>

    <view class="empty-state" wx:if="{{expectList.length === 0}}">
      <text>暂无申请</text>
    </view>
  </view>
</view>

<!-- 详情弹窗 -->
<view class="bottom-modal-mask {{showDetailModal ? 'show' : ''}}" bindtap="closeDetailModal">
  <view class="bottom-modal detail-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">{{currentItem.typeName}}-详情</text>
      <view class="modal-close" bindtap="closeDetailModal">×</view>
    </view>

    <view class="modal-body" wx:if="{{currentItem}}">
      <!-- 基本信息 -->
      <view class="detail-header">
        <text class="detail-user-name">{{currentItem.userName}}</text>
        <text class="type-badge {{currentItem.type}}">{{currentItem.typeName}}</text>
      </view>

      <!-- 期望排班详情 -->
      <block wx:if="{{currentItem.type === 'schedule'}}">
        <view class="detail-section">
          <view class="detail-row">
            <text class="detail-label">日期：</text>
            <text class="detail-value">{{currentItem.startDate}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">班次：</text>
            <text class="detail-value" style="color: {{currentItem.shiftColor || '#333'}}">{{currentItem.shiftCode ? currentItem.shiftCode + '-' : ''}}{{currentItem.shiftName || '无'}}</text>
          </view>
          <view class="detail-row" wx:if="{{currentItem.remark}}">
            <text class="detail-label">备注：</text>
            <text class="detail-value">{{currentItem.remark}}</text>
          </view>
          <view class="detail-row" wx:if="{{currentItem.approveRemark}}">
            <text class="detail-label">审批：</text>
            <text class="detail-value">{{currentItem.approveRemark}}</text>
          </view>
        </view>
      </block>

      <!-- 换班详情 -->
      <block wx:if="{{currentItem.type === 'swap'}}">
        <view class="detail-section">
          <view class="detail-row swap-detail-row">
            <text class="detail-label">日期：</text>
            <text class="detail-value swap-detail-left">{{currentItem.startDate}}</text>
            <text class="swap-detail-icon">⇄</text>
            <text class="detail-value swap-detail-right">{{currentItem.targetDate}}</text>
          </view>
          <view class="detail-row swap-detail-row">
            <text class="detail-label">对象：</text>
            <text class="detail-value swap-detail-left">{{currentItem.userName}}</text>
            <text class="swap-detail-icon">⇄</text>
            <text class="detail-value swap-detail-right">{{currentItem.targetUserName}}</text>
          </view>
          <view class="detail-row swap-detail-row">
            <text class="detail-label">班次：</text>
            <text class="detail-value swap-detail-left">{{currentItem.myShiftName || '无'}}</text>
            <text class="swap-detail-icon">⇄</text>
            <text class="detail-value swap-detail-right">{{currentItem.targetShiftName || '无'}}</text>
          </view>
          <view class="detail-row" wx:if="{{currentItem.remark}}">
            <text class="detail-label">备注：</text>
            <text class="detail-value">{{currentItem.remark}}</text>
          </view>
          <view class="detail-row" wx:if="{{currentItem.approveRemark}}">
            <text class="detail-label">审批：</text>
            <text class="detail-value">{{currentItem.approveRemark}}</text>
          </view>
        </view>
      </block>

      <!-- 审批操作 -->
      <block wx:if="{{currentItem.status === 'pending'}}">
        <view class="approval-section">
          <view class="approval-label">审批意见</view>
          <textarea
            class="approval-textarea"
            placeholder="请输入审批意见（选填）"
            placeholder-class="textarea-placeholder"
            value="{{approvalRemark}}"
            bindinput="onApprovalRemarkInput"
            maxlength="200"
            auto-height
          ></textarea>
        </view>

        <view class="approval-actions">
          <button class="btn-reject" bindtap="handleReject" data-id="{{currentItem.id}}">拒绝</button>
          <button class="btn-approve" bindtap="handleApprove" data-id="{{currentItem.id}}">通过</button>
        </view>
      </block>
    </view>
  </view>
</view>
