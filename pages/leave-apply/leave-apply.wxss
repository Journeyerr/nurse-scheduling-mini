/* pages/leave-apply/leave-apply.wxss */

.leave-container {
  min-height: 100vh;
  background: #F0F4F8;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.page-header {
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #4A90D9 0%, #6AA8E8 50%, #8BC0F5 100%);
}

.header-content {
  position: relative;
  padding: 60rpx 40rpx 48rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 主体区域 */
.section {
  margin: -24rpx 24rpx 0;
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-dot {
  width: 8rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #4A90D9, #6AA8E8);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A2B4A;
}

.btn-add {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #4A90D9, #5DA1E5);
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.35);
}

.btn-add:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-add-icon {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

.btn-add-text {
  font-size: 26rpx;
}

/* 申请列表 */
.apply-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.apply-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.apply-item-inner {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 24rpx;
  gap: 20rpx;
}

/* 左侧类型图标 */
.apply-type-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.apply-type-icon.leave {
  background: linear-gradient(135deg, #E8F4FD, #D0E8FB);
  color: #4A90D9;
}

.apply-type-icon.transfer {
  background: linear-gradient(135deg, #FFF3E0, #FFE4B5);
  color: #F57C00;
}

.apply-type-icon.exchange {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  color: #43A047;
}

/* 中间内容 */
.apply-info {
  flex: 1;
  min-width: 0;
}

.apply-info-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.apply-type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A2B4A;
}

.apply-status-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.apply-status-tag .status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.apply-status-tag.pending {
  background: #FFF8E1;
  color: #F5A623;
}

.apply-status-tag.pending .status-dot {
  background: #F5A623;
}

.apply-status-tag.approved {
  background: #E8F5E9;
  color: #43A047;
}

.apply-status-tag.approved .status-dot {
  background: #43A047;
}

.apply-status-tag.rejected {
  background: #FFEBEE;
  color: #E74C3C;
}

.apply-status-tag.rejected .status-dot {
  background: #E74C3C;
}

.apply-info-detail {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #5A6A80;
}

.detail-divider {
  font-size: 24rpx;
  color: #C8D0DA;
}

.apply-info-reason {
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  background: #F5F7FA;
  border-radius: 8rpx;
}

.apply-info-reason text {
  font-size: 24rpx;
  color: #7A8A9E;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 50rpx 60rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: #F0F4F8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-emoji {
  font-size: 52rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #5A6A80;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #A0AEBF;
}

/* ==================== 底部弹窗 ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.bottom-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.modal-mask.show .bottom-modal {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #F0F2F5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A2B4A;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F7FA;
}

.close-icon {
  font-size: 36rpx;
  color: #7A8A9E;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
}

.modal-body-inner {
  padding: 28rpx 32rpx;
}

.modal-footer {
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F2F5;
}

/* ==================== 表单样式 ==================== */
.form-group {
  margin-bottom: 32rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.label-dot {
  width: 6rpx;
  height: 24rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #4A90D9, #6AA8E8);
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

/* 类型选择 */
.type-options {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  padding: 24rpx 12rpx;
  text-align: center;
  background: #F5F7FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-option:active {
  transform: scale(0.97);
}

.type-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  margin: 0 auto 12rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.type-icon-wrap.leave-icon {
  background: #E8F4FD;
  color: #4A90D9;
}

.type-icon-wrap.transfer-icon {
  background: #FFF3E0;
  color: #F57C00;
}

.type-icon-wrap.exchange-icon {
  background: #E8F5E9;
  color: #43A047;
}

.type-text {
  font-size: 26rpx;
  color: #5A6A80;
}

.type-option.active {
  background: #fff;
}

.type-option.leave-active {
  border-color: #4A90D9;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.15);
}

.type-option.leave-active .type-text {
  color: #4A90D9;
  font-weight: 600;
}

.type-option.transfer-active {
  border-color: #F57C00;
  box-shadow: 0 4rpx 16rpx rgba(245, 124, 0, 0.15);
}

.type-option.transfer-active .type-text {
  color: #F57C00;
  font-weight: 600;
}

.type-option.exchange-active {
  border-color: #43A047;
  box-shadow: 0 4rpx 16rpx rgba(67, 160, 71, 0.15);
}

.type-option.exchange-active .type-text {
  color: #43A047;
  font-weight: 600;
}

/* 时间选择 */
.time-picker-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.time-picker-card {
  flex: 1;
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.time-picker-card.placeholder .time-value {
  color: #B8C4D0;
}

.time-label {
  display: block;
  font-size: 22rpx;
  color: #8A9EB5;
  margin-bottom: 6rpx;
}

.time-value {
  font-size: 26rpx;
  color: #2C3E50;
  font-weight: 500;
}

.time-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4rpx;
}

.arrow-line {
  color: #B8C4D0;
  font-size: 28rpx;
}

/* 选择器卡片 */
.picker-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
}

.picker-card.placeholder .picker-value {
  color: #B8C4D0;
}

.picker-value {
  font-size: 28rpx;
  color: #2C3E50;
}

.picker-arrow {
  font-size: 32rpx;
  color: #B8C4D0;
}

/* 事由说明 */
.textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2C3E50;
  box-sizing: border-box;
  line-height: 1.6;
}

.textarea-placeholder {
  color: #B8C4D0;
}

.textarea-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #B8C4D0;
  margin-top: 8rpx;
}

/* 提交按钮 */
.btn-submit-form {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #4A90D9, #5DA1E5);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: 46rpx;
  padding: 0;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
}

.btn-submit-form::after {
  border: none;
}

.btn-submit-form:active {
  opacity: 0.9;
}
