<!--pages/leave-apply/leave-apply.wxml-->
<view class="leave-container">
  <!-- 我的申请记录 -->
  <view class="section card">
    <view class="section-header">
      <text class="section-title">我的申请记录</text>
      <button class="btn-add" bindtap="addApply">+ 申请</button>
    </view>
    
    <view class="apply-list">
      <view class="apply-item" wx:for="{{myApplies}}" wx:key="id">
        <view class="apply-header">
          <text class="apply-type {{item.type}}">{{item.typeName}}</text>
          <text class="apply-status {{item.status}}">{{item.statusName}}</text>
        </view>
        <view class="apply-content">
          <view class="apply-row">
            <text class="apply-label">时间：</text>
            <text class="apply-value">{{item.startDate}} 至 {{item.endDate}}</text>
          </view>
          <view class="apply-row">
            <text class="apply-label">天数：</text>
            <text class="apply-value">{{item.days}}天</text>
          </view>
          <view class="apply-row" wx:if="{{item.reason}}">
            <text class="apply-label">事由：</text>
            <text class="apply-value">{{item.reason}}</text>
          </view>
        </view>
      </view>
      
      <view class="empty-state" wx:if="{{myApplies.length === 0}}">
        <text>暂无申请记录</text>
      </view>
    </view>
  </view>

  <!-- 申请弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">假勤申请</text>
        <view class="modal-close" bindtap="closeModal">×</view>
      </view>
      
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">申请类型</text>
          <view class="type-options">
            <view 
              class="type-option {{applyType === 'leave' ? 'active' : ''}}" 
              bindtap="selectType" 
              data-type="leave"
            >
              请假
            </view>
            <view 
              class="type-option {{applyType === 'transfer' ? 'active' : ''}}" 
              bindtap="selectType" 
              data-type="transfer"
            >
              调班
            </view>
            <view 
              class="type-option {{applyType === 'exchange' ? 'active' : ''}}" 
              bindtap="selectType" 
              data-type="exchange"
            >
              换班
            </view>
          </view>
        </view>
        
        <view class="form-item">
          <text class="form-label">开始时间</text>
          <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
            <view class="picker-value">{{startDate || '请选择'}}</view>
          </picker>
        </view>
        
        <view class="form-item">
          <text class="form-label">结束时间</text>
          <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
            <view class="picker-value">{{endDate || '请选择'}}</view>
          </picker>
        </view>
        
        <view class="form-item" wx:if="{{applyType === 'exchange'}}">
          <text class="form-label">换班对象</text>
          <picker mode="selector" range="{{members}}" range-key="nickName" bindchange="onMemberChange">
            <view class="picker-value">{{selectedMemberName || '请选择'}}</view>
          </picker>
        </view>
        
        <view class="form-item">
          <text class="form-label">事由说明</text>
          <textarea 
            class="textarea" 
            placeholder="请输入事由说明" 
            value="{{reason}}"
            bindinput="onReasonInput"
            maxlength="200"
          ></textarea>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="btn-primary" bindtap="submitApply">提交申请</button>
      </view>
    </view>
  </view>
</view>
