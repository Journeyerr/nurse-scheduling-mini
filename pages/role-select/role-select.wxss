/* pages/role-select/role-select.wxss */

.role-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F5F7FA;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

/* 顶部说明 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  margin-bottom: 80rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 身份选择卡片 */
.role-cards {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.role-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.role-card:active {
  background: #F8F9FA;
}

.role-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.role-icon.nurse {
  background: linear-gradient(135deg, #27AE60 0%, #1E8449 100%);
}

.icon-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.role-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.role-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.role-desc {
  font-size: 26rpx;
  color: #999;
}

.role-arrow {
  margin-left: 20rpx;
}

.arrow {
  font-size: 48rpx;
  color: #CCC;
}

/* 底部说明 */
.footer {
  position: fixed;
  bottom: 60rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #BBB;
}
