/* pages/member-info/member-info.wxss */

.member-info-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 140rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
}

.avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.3);
}

.avatar-text text {
  font-size: 64rpx;
  color: #fff;
  font-weight: bold;
}

.member-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-creator {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}

/* 信息表单 */
.info-section {
  margin: 20rpx;
  padding: 0 30rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-item:last-child {
  border-bottom: none;
}

.textarea-item {
  align-items: flex-start;
}

.info-label {
  width: 140rpx;
  font-size: 30rpx;
  color: #666;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  text-align: right;
}

.info-textarea {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  min-height: 80rpx;
  line-height: 1.6;
}

.info-value[disabled] {
  color: #999;
}

.info-textarea[disabled] {
  color: #999;
}

/* 保存按钮 */
.btn-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: transparent;
  box-shadow: none;
  padding: 0;
}

.submit-btn {
  width: 100% !important;
  height: 110rpx;
  line-height: 110rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
  border-radius: 0;
  padding: 0 !important;
  margin: 0;
  box-shadow: 0 -4rpx 20rpx rgba(74, 144, 217, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.submit-btn::before {
  display: none;
}

.submit-btn::after {
  display: none;
  border: none;
}

.submit-btn[disabled] {
  background: #B8B8B8;
  color: #666;
  box-shadow: none;
}

.submit-btn:not([disabled]):active {
  background: linear-gradient(135deg, #357ABD 0%, #2868A8 100%);
}
