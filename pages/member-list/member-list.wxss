/* pages/member-list/member-list.wxss */

.member-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 20rpx;
}

/* 搜索框 */
.search-section {
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.search-input {
  background: #F5F7FA;
  border-radius: 30rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

/* 成员列表 */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.member-card {
  display: flex;
  padding: 30rpx;
}

.member-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
}

.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-bottom: 10rpx;
}

.member-avatar-text {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-avatar-text text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.member-info-section {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.member-join-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.member-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F8F9FA;
  border-radius: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A90D9;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.member-actions {
  display: flex;
  align-items: center;
}

.btn-kick {
  background: #FFEBEE;
  color: #E74C3C;
  font-size: 26rpx;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  border: none;
}

.empty-state {
  padding: 100rpx 0;
  text-align: center;
  color: #999;
}
