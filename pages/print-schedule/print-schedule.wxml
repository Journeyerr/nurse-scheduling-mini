<!--pages/print-schedule/print-schedule.wxml-->
<view class="print-container">
  <!-- 月份选择 -->
  <view class="month-selector card">
    <view class="selector-btn" bindtap="prevMonth">
      <text class="arrow">‹</text>
    </view>
    <text class="current-month">{{department.name}} - {{currentYear}}年{{currentMonth}}月排班统计</text>
    <view class="selector-btn" bindtap="nextMonth">
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 排班表预览 -->
  <view class="schedule-preview card" id="scheduleCanvas">
    <view class="preview-table">
      <!-- 表头 -->
      <view class="table-row header-row">
        <view class="table-cell" style="width: {{cellWidths.name}}rpx; min-width: {{cellWidths.name}}rpx;">姓名</view>
        <view class="table-cell shift-header" wx:for="{{shiftList}}" wx:key="id" style="width: {{cellWidths.shift}}rpx; min-width: {{cellWidths.shift}}rpx;">
          <view class="shift-badge-small" style="background-color: {{item.color}}20; border-color: {{item.color}}; color: {{item.color}}; width: {{cellWidths.shift - 8}}rpx; text-align: center;">
            {{item.name}}
          </view>
        </view>
        <view class="table-cell" style="width: {{cellWidths.coefficient}}rpx; min-width: {{cellWidths.coefficient}}rpx;">系数</view>
      </view>

      <!-- 数据行 -->
      <view class="table-row" wx:for="{{statisticsData}}" wx:key="memberId">
        <view class="table-cell name-cell" style="width: {{cellWidths.name}}rpx; min-width: {{cellWidths.name}}rpx;">{{item.memberName}}</view>
        <view class="table-cell" wx:for="{{item.shiftCounts}}" wx:key="shiftId" style="width: {{cellWidths.shift}}rpx; min-width: {{cellWidths.shift}}rpx;">
          <text class="count-text">{{item.count || '-'}}</text>
        </view>
        <view class="table-cell" style="width: {{cellWidths.coefficient}}rpx; min-width: {{cellWidths.coefficient}}rpx;">
          <text class="coefficient-text">{{item.coefficientSum || '-'}}</text>
        </view>
      </view>
    </view>

    <!-- 图例 -->
    <view class="legend-section">
      <!-- <text class="legend-title">图例：</text> -->
      <view class="legend-list">
        <view class="legend-item" wx:for="{{shiftList}}" wx:key="id">
          <view class="legend-color" style="background-color: {{item.color}}"></view>
          <text class="legend-text">{{item.code}}: {{item.name}}（×{{item.coefficient || 1.0}}）</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Canvas 用于生成图片 -->
  <canvas type="2d" id="myCanvas" style="position: absolute; left: -9999px; width: 750px; height: 1334px;"></canvas>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn-primary" bindtap="saveImage">保存图片</button>
    <button class="btn-secondary" open-type="share">分享排班</button>
  </view>
</view>
