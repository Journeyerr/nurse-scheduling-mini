/* pages/shift-manage/shift-manage.wxss */

.shift-container {
  padding: 20rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
  background: #F5F7FA;
}

/* 套班管理入口 */
.package-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.entry-left {
  display: flex;
  align-items: center;
}

.entry-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.entry-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.entry-arrow-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}

/* 班种列表 */
.shift-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.shift-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.shift-left {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.shift-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
}

.shift-content {
  flex: 1;
  min-width: 0;
}

.shift-header {
  margin-bottom: 6rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.shift-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.shift-code-tag {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.shift-rest-tag {
  font-size: 20rpx;
  color: #52C41A;
  background: #F6FFED;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  border: 1rpx solid #B7EB8F;
}

.shift-times {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.time-slot {
  display: inline-flex;
}

.time-text {
  font-size: 24rpx;
  color: #999;
}

.shift-duration {
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 500;
  margin-left: 4rpx;
}

.shift-coefficient {
  font-size: 24rpx;
  color: #E89B7C;
  margin-left: 4rpx;
}

.shift-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.action-btn {
  font-size: 26rpx;
  padding: 4rpx 0;
}

.action-btn.edit {
  color: #4A90D9;
}

.action-btn.delete {
  color: #E74C3C;
}

.empty-state {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 217, 0.35);
}

.add-btn-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.add-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

.add-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* ============ 底部滑入弹窗 ============ */
.bottom-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.bottom-modal-mask.show {
  visibility: visible;
  opacity: 1;
}

.bottom-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.bottom-modal-mask.show .bottom-modal {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.modal-close {
  font-size: 44rpx;
  color: #999;
  line-height: 1;
  width: 48rpx;
  text-align: center;
}

.modal-body {
  flex: 1;
  max-height: 62vh;
}

.modal-body-inner {
  padding: 28rpx 32rpx;
}

/* ============ 弹窗内表单样式 ============ */

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #4A90D9;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.section-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

/* 表单组 */
.form-group {
  margin-bottom: 28rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.label-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #4A90D9;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.form-label-sub {
  font-size: 24rpx;
  color: #AAA;
  margin-left: 12rpx;
}

/* 输入框 */
.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s;
}

.form-input:focus {
  background: #F0F4FF;
}

.input-placeholder {
  color: #C8C8C8;
  font-size: 28rpx;
}

.input-count {
  position: absolute;
  right: 24rpx;
  font-size: 22rpx;
  color: #C8C8C8;
}

/* 编号输入框带预览徽章 */
.input-code-wrapper .form-input {
  padding-right: 120rpx;
}

.code-preview-badge {
  position: absolute;
  right: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 10rpx;
}

/* 分割线 */
.form-divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 28rpx 0;
}

/* 时间段卡片 */
.time-slots {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.time-slot-card {
  background: #FAFBFC;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.time-slot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.time-slot-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.time-slot-actions {
  display: flex;
  gap: 16rpx;
}

.time-action-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.time-action-btn.add-action {
  background: #E8F4FD;
}

.time-action-btn.remove-action {
  background: #FDE8E8;
}

.action-icon {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.add-icon {
  color: #4A90D9;
}

.remove-icon {
  color: #E74C3C;
}

.action-text {
  font-size: 22rpx;
}

.add-action .action-text {
  color: #4A90D9;
}

.remove-action .action-text {
  color: #E74C3C;
}

/* 时间选择行 */
.time-slot-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.time-picker-card {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.time-picker-label {
  font-size: 22rpx;
  color: #BBB;
  margin-right: 4rpx;
}

.time-picker-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  flex: 1;
}

.next-day-badge {
  font-size: 20rpx;
  color: #4A90D9;
  background: #E8F4FD;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.time-arrow {
  flex-shrink: 0;
  padding: 0 4rpx;
}

.arrow-line {
  font-size: 28rpx;
  color: #CCC;
}

/* 行内表单（时长+系数） */
.inline-form-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 0;
}

.inline-form-item {
  flex: 1;
}

.inline-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: block;
}

.inline-input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.inline-input {
  width: 100%;
  height: 92rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 0 80rpx 0 28rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s;
}

.inline-input:focus {
  background: #F0F4FF;
}

.inline-unit {
  position: absolute;
  right: 24rpx;
  font-size: 26rpx;
  color: #999;
}

/* 开关行 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0 28rpx;
}

.switch-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.switch-desc {
  font-size: 24rpx;
  color: #AAA;
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 8rpx 0;
}

.color-item {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.color-item.active {
  border-color: #333;
  transform: scale(1.15);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.color-check {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 预览 */
.preview-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.preview-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

.preview-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FAFBFC;
  border-radius: 16rpx;
}

.preview-badge {
  font-size: 36rpx;
  font-weight: 800;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.preview-detail {
  flex: 1;
  min-width: 0;
}

.preview-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.preview-times {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.preview-time {
  font-size: 22rpx;
  color: #888;
  background: #fff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.preview-duration {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.duration-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A90D9;
}

.duration-unit {
  font-size: 22rpx;
  color: #4A90D9;
  font-weight: 500;
}

/* 底部按钮 */
.modal-footer {
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F0F0;
}

.btn-primary {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  border: none;
  border-radius: 48rpx !important;
  padding: 0 !important;
  margin: 0;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.btn-primary::before {
  display: none;
}

.btn-primary::after {
  display: none;
  border: none;
}

.btn-primary[disabled] {
  background: #D9D9D9;
  color: #fff;
  box-shadow: none;
}

.btn-primary:not([disabled]):active {
  background: linear-gradient(135deg, #357ABD 0%, #2868A8 100%);
  transform: scale(0.98);
}

/* ============ 时间选择弹窗 ============ */
.time-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
}

.time-modal {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.time-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.time-modal-cancel {
  font-size: 28rpx;
  color: #999;
}

.time-modal-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.time-modal-confirm {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: 600;
}

/* 今日/次日切换 */
.day-toggle {
  display: flex;
  padding: 20rpx 36rpx;
  gap: 12rpx;
}

.day-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F7FA;
  transition: all 0.2s;
  font-weight: 500;
}

.day-option.active {
  background: #4A90D9;
  color: #fff;
}

/* 时间选择器 */
.time-selector {
  height: 440rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.time-selector picker-view {
  height: 100%;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
}
