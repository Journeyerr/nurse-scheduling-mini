<!--pages/shift-manage/shift-manage.wxml-->
<view class="shift-container">
  <!-- 套班管理入口 -->
  <view class="package-entry card" bindtap="goShiftPackage">
    <view class="entry-left">
      <text class="entry-icon">📦</text>
      <text class="entry-text">套班管理</text>
    </view>
    <image class="entry-arrow-icon" src="/assets/images/arrow-right.png" mode="aspectFit" />
  </view>

  <!-- 班种列表 -->
  <view class="shift-list">
    <view class="shift-item card" wx:for="{{shiftList}}" wx:key="id">
      <view class="shift-left">
        <view class="shift-dot" style="background-color: {{item.color}}"></view>
      </view>
      <view class="shift-content">
        <view class="shift-header">
          <text class="shift-name">{{item.name}}</text>
          <text class="shift-code-tag" style="color: {{item.color}}; background: {{item.color}}15;">{{item.code}}</text>
          <text class="shift-rest-tag" wx:if="{{item.isRest}}">休息</text>
        </view>
        <view class="shift-times">
          <view class="time-slot" wx:for="{{item.timeSlots || []}}" wx:for-item="slot" wx:key="index">
            <text class="time-text">{{slot.startTime}}{{slot.startIsNextDay ? '次日' : ''}}-{{slot.endTime}}{{slot.endIsNextDay ? '次日' : ''}}</text>
          </view>
          <view class="time-slot" wx:if="{{!item.timeSlots && item.startTime}}">
            <text class="time-text">{{item.startTime}}-{{item.endTime}}</text>
          </view>
          <text class="shift-duration" wx:if="{{item.duration}}">{{item.duration}}h</text>
          <text class="shift-coefficient" wx:if="{{item.coefficient && item.coefficient != 1 && item.coefficient != 1.0}}">×{{item.coefficient}}</text>
        </view>
      </view>
      <view class="shift-actions">
        <text class="action-btn edit" bindtap="editShift" data-id="{{item.id}}">编辑</text>
        <text class="action-btn delete" bindtap="deleteShift" data-id="{{item.id}}">删除</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{shiftList.length === 0}}">
      <text>暂无班种，请点击下方按钮添加</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="addShift">
    <view class="add-btn-circle">
      <text class="add-icon">+</text>
    </view>
    <text class="add-text">添加班种</text>
  </view>
</view>

<!-- 底部滑入弹窗 -->
<view class="bottom-modal-mask {{showEditModal ? 'show' : ''}}" bindtap="closeEditModal" catchtouchmove="preventTouchMove">
  <view class="bottom-modal" catchtap="stopPropagation">
    <view class="modal-header" catchtouchmove="preventTouchMove">
      <text class="modal-title">{{isEdit ? '编辑班种' : '添加班种'}}</text>
      <view class="modal-close" bindtap="closeEditModal">×</view>
    </view>

    <scroll-view class="modal-body" scroll-y>
      <view class="modal-body-inner">
      <!-- <view class="section-title">
        <text class="section-dot"></text>
        <text class="section-text">基本信息</text>
      </view> -->

      <!-- 班种编号 -->
      <view class="form-group">
        <view class="form-label-row">
          <text class="label-dot"></text>
          <text class="form-label">班种编号</text>
          <text class="form-label-sub">日历上显示的代号</text>
        </view>
        <view class="input-wrapper input-code-wrapper">
          <input
            class="form-input"
            placeholder="如 A、B、N"
            placeholder-class="input-placeholder"
            value="{{editingShift.code}}"
            bindinput="onCodeInput"
            maxlength="2"
          />
          <view class="code-preview-badge" style="color: {{editingShift.color}}; background: {{editingShift.color}}15;">
            {{editingShift.code || 'A'}}
          </view>
        </view>
      </view>

      <!-- 班种名称 -->
      <view class="form-group">
        <view class="form-label-row">
          <text class="label-dot"></text>
          <text class="form-label">班种名称</text>
        </view>
        <view class="input-wrapper">
          <input
            class="form-input"
            placeholder="如 白班、夜班"
            placeholder-class="input-placeholder"
            value="{{editingShift.name}}"
            bindinput="onNameInput"
            maxlength="10"
          />
          <text class="input-count" wx:if="{{editingShift.name.length > 0}}">{{editingShift.name.length}}/10</text>
        </view>
      </view>

      <!-- 分割线 -->
      <view class="form-divider"></view>

      <!-- 时间设置 -->
      <!-- <view class="section-title">
        <text class="section-dot"></text>
        <text class="section-text">时间设置</text>
      </view> -->

      <view class="time-slots">
        <view class="time-slot-card" wx:for="{{editingShift.timeSlots}}" wx:key="index">
          <view class="time-slot-header">
            <text class="time-slot-label">时间段 {{editingShift.timeSlots.length > 1 ? index + 1 : ''}}</text>
            <view class="time-slot-actions">
              <view class="time-action-btn add-action" wx:if="{{index === 0 && editingShift.timeSlots.length < 2}}" bindtap="addTimeSlot">
                <text class="action-icon add-icon">+</text>
                <text class="action-text">添加</text>
              </view>
              <view class="time-action-btn remove-action" wx:if="{{index === 1}}" bindtap="removeTimeSlot" data-index="{{index}}">
                <text class="action-icon remove-icon">−</text>
                <text class="action-text">删除</text>
              </view>
            </view>
          </view>
          <view class="time-slot-row">
            <view class="time-picker-card" bindtap="showStartTimePicker" data-index="{{index}}">
              <text class="time-picker-label">开始</text>
              <text class="time-picker-value">{{item.startTime || '选择时间'}}</text>
              <text class="next-day-badge" wx:if="{{item.startIsNextDay}}">次日</text>
            </view>
            <view class="time-arrow">
              <text class="arrow-line">→</text>
            </view>
            <view class="time-picker-card" bindtap="showEndTimePicker" data-index="{{index}}">
              <text class="time-picker-label">结束</text>
              <text class="time-picker-value">{{item.endTime || '选择时间'}}</text>
              <text class="next-day-badge" wx:if="{{item.endIsNextDay}}">次日</text>
            </view>
          </view>
        </view>
      </view>

      <view class="inline-form-row">
        <view class="inline-form-item">
          <text class="inline-label">时长</text>
          <view class="inline-input-wrapper">
            <input class="inline-input" type="digit" placeholder="自动计算" placeholder-class="input-placeholder" value="{{editingShift.duration}}" bindinput="onDurationInput" />
            <text class="inline-unit">小时</text>
          </view>
        </view>
        <view class="inline-form-item">
          <text class="inline-label">系数</text>
          <view class="inline-input-wrapper">
            <input class="inline-input" type="digit" placeholder="1.0" placeholder-class="input-placeholder" value="{{editingShift.coefficient}}" bindinput="onCoefficientInput" />
          </view>
        </view>
      </view>

      <!-- 分割线 -->
      <view class="form-divider"></view>

      <!-- 其他设置 -->
      <!-- <view class="section-title">
        <text class="section-dot"></text>
        <text class="section-text">其他设置</text>
      </view> -->

      <view class="switch-row">
        <view class="switch-info">
          <text class="switch-label">休息班</text>
          <text class="switch-desc">不计入工作排班数</text>
        </view>
        <switch checked="{{editingShift.isRest}}" bindchange="toggleIsRest" color="#4A90D9" />
      </view>

      <view class="form-group">
        <view class="form-label-row">
          <text class="label-dot"></text>
          <text class="form-label">编号颜色</text>
        </view>
        <view class="color-picker">
          <view 
            class="color-item {{editingShift.color === item ? 'active' : ''}}" 
            wx:for="{{colorList}}" 
            wx:key="*this"
            style="background-color: {{item}}"
            bindtap="selectColor"
            data-color="{{item}}"
          >
            <text class="color-check" wx:if="{{editingShift.color === item}}">✓</text>
          </view>
        </view>
      </view>

      <!-- 预览 -->
      <view class="preview-section">
        <text class="preview-title">预览效果</text>
        <view class="preview-card">
          <view class="preview-badge" style="color: {{editingShift.color}}; background: {{editingShift.color}}12;">
            {{editingShift.code || 'A'}}
          </view>
          <view class="preview-detail">
            <text class="preview-name">{{editingShift.name || '班种名称'}}</text>
            <view class="preview-times" wx:if="{{editingShift.timeSlots.length > 0}}">
              <text class="preview-time" wx:for="{{editingShift.timeSlots}}" wx:key="index">
                {{item.startTime || '00:00'}}-{{item.endTime || '00:00'}}{{item.endIsNextDay ? '次日' : ''}}
              </text>
            </view>
          </view>
          <view class="preview-duration" wx:if="{{editingShift.duration}}">
            <text class="duration-value">{{editingShift.duration}}</text>
            <text class="duration-unit">h</text>
          </view>
        </view>
      </view>
      </view>
    </scroll-view>

    <view class="modal-footer" catchtouchmove="preventTouchMove">
      <button class="btn-primary" bindtap="submitShift" disabled="{{!canSubmit}}">{{isEdit ? '保存修改' : '创建班种'}}</button>
    </view>
  </view>
</view>

<!-- 时间选择弹窗 -->
<view class="time-modal-mask" wx:if="{{showTimePickerModal}}" bindtap="hideTimePicker">
  <view class="time-modal" catchtap="stopPropagation">
    <view class="time-modal-header">
      <text class="time-modal-cancel" bindtap="hideTimePicker">取消</text>
      <text class="time-modal-title">选择时间</text>
      <text class="time-modal-confirm" bindtap="confirmTime">确定</text>
    </view>

    <!-- 今日/次日切换 -->
    <view class="day-toggle">
      <view class="day-option {{!tempIsNextDay ? 'active' : ''}}" bindtap="toggleDay" data-day="today">
        <text>今日</text>
      </view>
      <view class="day-option {{tempIsNextDay ? 'active' : ''}}" bindtap="toggleDay" data-day="next">
        <text>次日</text>
      </view>
    </view>

    <!-- 时间选择器 -->
    <view class="time-selector">
      <picker-view indicator-style="height: 44px;" value="{{pickerValue}}" bindchange="onTimeChange">
        <picker-view-column>
          <view class="picker-item" wx:for="{{hours}}" wx:key="*this">{{item}}时</view>
        </picker-view-column>
        <picker-view-column>
          <view class="picker-item" wx:for="{{minutes}}" wx:key="*this">{{item}}分</view>
        </picker-view-column>
      </picker-view>
    </view>
  </view>
</view>
