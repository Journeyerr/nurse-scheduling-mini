<!--pages/shift-manage/shift-manage.wxml-->
<view class="shift-container">
  <!-- 套餐管理入口 -->
  <view class="package-entry card" bindtap="goShiftPackage">
    <view class="entry-left">
      <text class="entry-icon">📦</text>
      <text class="entry-text">套餐管理</text>
    </view>
    <text class="entry-arrow">›</text>
  </view>

  <!-- 班种列表 -->
  <view class="shift-list">
    <view class="shift-item card" wx:for="{{shiftList}}" wx:key="id">
      <view class="shift-left">
        <view class="shift-badge" style="background-color: {{item.color}}20; border-color: {{item.color}}">
          <text class="badge-code" style="color: {{item.color}}">{{item.code}}</text>
        </view>
      </view>
      <view class="shift-content">
        <view class="shift-header">
          <text class="shift-name">{{item.name}}</text>
          <text class="shift-rest-tag" wx:if="{{item.isRest}}">休息</text>
        </view>
        <view class="shift-times">
          <view class="time-slot" wx:for="{{item.timeSlots || []}}" wx:for-item="slot" wx:key="index">
            <text class="time-text">{{slot.startTime}}{{slot.startIsNextDay ? '次日' : ''}}-{{slot.endTime}}{{slot.endIsNextDay ? '次日' : ''}}</text>
          </view>
          <view class="time-slot" wx:if="{{!item.timeSlots && item.startTime}}">
            <text class="time-text">{{item.startTime}}-{{item.endTime}}</text>
          </view>
          <text class="shift-duration" wx:if="{{item.duration}}">{{item.duration}}h</text>
          <text class="shift-coefficient" wx:if="{{item.coefficient && item.coefficient != 1 && item.coefficient != 1.0}}">×{{item.coefficient}}</text>
        </view>
      </view>
      <view class="shift-actions">
        <text class="action-btn edit" bindtap="editShift" data-id="{{item.id}}">编辑</text>
        <text class="action-btn delete" bindtap="deleteShift" data-id="{{item.id}}">删除</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{shiftList.length === 0}}">
      <text>暂无班种，请点击下方按钮添加</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="addShift">
    <text class="add-icon">+</text>
    <text class="add-text">添加班种</text>
  </view>
</view>

<!-- 底部滑入弹窗 -->
<view class="bottom-modal-mask {{showEditModal ? 'show' : ''}}" bindtap="closeEditModal">
  <view class="bottom-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">{{isEdit ? '编辑班种' : '添加班种'}}</text>
      <view class="modal-close" bindtap="closeEditModal">×</view>
    </view>

    <view class="modal-body">
      <!-- 班种编号 -->
      <view class="form-item">
        <text class="form-label">班种编号（代号）</text>
        <input
          class="form-input"
          placeholder="如：A、B、N"
          placeholder-class="input-placeholder"
          value="{{editingShift.code}}"
          bindinput="onCodeInput"
          maxlength="2"
        />
      </view>

      <!-- 班种名称 -->
      <view class="form-item">
        <text class="form-label">班种名称</text>
        <input
          class="form-input"
          placeholder="如：白班、夜班"
          placeholder-class="input-placeholder"
          value="{{editingShift.name}}"
          bindinput="onNameInput"
          maxlength="10"
        />
      </view>

      <!-- 工作时间段 -->
      <view class="form-item">
        <text class="form-label">工作时间段</text>
        <view class="time-slots-container">
          <view class="time-slot-item" wx:for="{{editingShift.timeSlots}}" wx:key="index">
            <view class="time-row">
              <view class="time-col">
                <text class="time-col-label">开始</text>
                <view class="time-picker" bindtap="showStartTimePicker" data-index="{{index}}">
                  <text class="time-text">{{item.startTime || '00:00'}}</text>
                  <text class="next-day-tag" wx:if="{{item.startIsNextDay}}">次日</text>
                </view>
              </view>
              <view class="time-col">
                <text class="time-col-label">结束</text>
                <view class="time-picker" bindtap="showEndTimePicker" data-index="{{index}}">
                  <text class="time-text">{{item.endTime || '00:00'}}</text>
                  <text class="next-day-tag" wx:if="{{item.endIsNextDay}}">次日</text>
                </view>
              </view>
              <!-- 操作按钮 -->
              <view class="time-action {{index === 0 && editingShift.timeSlots.length < 2 ? 'add-action' : ''}}" 
                    wx:if="{{(index === 0 && editingShift.timeSlots.length < 2) || index === 1}}"
                    bindtap="{{index === 0 ? 'addTimeSlot' : 'removeTimeSlot'}}"
                    data-index="{{index}}">
                <text class="{{index === 0 ? 'add-btn-text' : 'remove-btn-text'}}">{{index === 0 ? '+' : '−'}}</text>
              </view>
              <view class="time-action-placeholder" wx:if="{{index === 0 && editingShift.timeSlots.length >= 2}}"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- 时长 / 班种系数 / 休息班 一行布局 -->
      <view class="form-item">
        <view class="inline-fields">
          <view class="inline-field">
            <text class="form-label">时长(小时)</text>
            <input
              class="form-input"
              type="digit"
              placeholder="自动计算"
              placeholder-class="input-placeholder"
              value="{{editingShift.duration}}"
              bindinput="onDurationInput"
            />
          </view>
          <view class="inline-field">
            <text class="form-label">班种系数</text>
            <input
              class="form-input"
              type="digit"
              placeholder="1.0"
              placeholder-class="input-placeholder"
              value="{{editingShift.coefficient}}"
              bindinput="onCoefficientInput"
            />
          </view>
          <view class="inline-field switch-field">
            <text class="form-label">休息班</text>
            <switch
              checked="{{editingShift.isRest}}"
              bindchange="toggleIsRest"
              color="#4A90D9"
            />
          </view>
        </view>
      </view>

      <!-- 颜色选择 -->
      <view class="form-item">
        <text class="form-label">编号字体颜色</text>
        <view class="color-picker">
          <view 
            class="color-item {{editingShift.color === item ? 'active' : ''}}" 
            wx:for="{{colorList}}" 
            wx:key="*this"
            style="background-color: {{item}}"
            bindtap="selectColor"
            data-color="{{item}}"
          >
            <text class="check-icon" wx:if="{{editingShift.color === item}}">✓</text>
          </view>
        </view>
      </view>

      <!-- 预览 -->
      <view class="form-item">
        <text class="form-label">预览效果</text>
        <view class="preview-box">
          <view class="preview-tag" style="background-color: {{editingShift.color}}20; border-color: {{editingShift.color}}">
            <text class="preview-code" style="color: {{editingShift.color}}">{{editingShift.code || 'A'}}</text>
          </view>
          <view class="preview-info">
            <view class="preview-name-row">
              <text class="preview-name">{{editingShift.name || '班种名称'}}</text>
              <text class="preview-duration" wx:if="{{editingShift.duration}}">{{editingShift.duration}}h</text>
            </view>
            <view class="preview-times">
              <text class="preview-time" wx:for="{{editingShift.timeSlots}}" wx:key="index">
                {{item.startTime || '00:00'}}-{{item.endTime || '00:00'}}{{item.endIsNextDay ? '次日' : ''}}
              </text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="modal-footer">
      <button class="btn-primary" bindtap="submitShift" disabled="{{!canSubmit}}">提交</button>
    </view>
  </view>
</view>

<!-- 时间选择弹窗 -->
<view class="time-modal-mask" wx:if="{{showTimePickerModal}}" bindtap="hideTimePicker">
  <view class="time-modal" catchtap="stopPropagation">
    <view class="time-modal-header">
      <view class="time-modal-btn cancel" bindtap="hideTimePicker">取消</view>
      <text class="time-modal-title">选择时间</text>
      <view class="time-modal-btn" bindtap="confirmTime">确定</view>
    </view>

    <!-- 今日/次日切换 -->
    <view class="day-toggle">
      <view class="day-option {{!tempIsNextDay ? 'active' : ''}}" bindtap="toggleDay" data-day="today">
        <text>今日</text>
      </view>
      <view class="day-option {{tempIsNextDay ? 'active' : ''}}" bindtap="toggleDay" data-day="next">
        <text>次日</text>
      </view>
    </view>

    <!-- 时间选择器 -->
    <view class="time-selector">
      <picker-view indicator-style="height: 44px;" value="{{pickerValue}}" bindchange="onTimeChange">
        <picker-view-column>
          <view class="picker-item" wx:for="{{hours}}" wx:key="*this">{{item}}时</view>
        </picker-view-column>
        <picker-view-column>
          <view class="picker-item" wx:for="{{minutes}}" wx:key="*this">{{item}}分</view>
        </picker-view-column>
      </picker-view>
    </view>
  </view>
</view>
