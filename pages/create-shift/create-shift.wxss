/* pages/create-shift/create-shift.wxss */

.create-shift-container {
  padding: 20rpx;
  padding-bottom: 140rpx;
  min-height: 100vh;
  background: #F5F7FA;
}

.form-section {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

/* 输入框样式优化 */
.input {
  width: 100%;
  background: #F5F7FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  height: 76rpx;
  line-height: 76rpx;
  display: flex;
  align-items: center;
}

.input-placeholder {
  color: #BBB;
  font-size: 28rpx;
}

/* 系数输入行 */
.form-row-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-row-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex-shrink: 0;
}

.form-row-left .form-label {
  margin-bottom: 0;
}

.form-hint {
  font-size: 22rpx;
  color: #BBB;
}

.input.input-small {
  width: 200rpx !important;
  flex: none;
  text-align: right;
  min-height: 76rpx;
}

/* 休息班开关行 */
.form-switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 8rpx;
}

.switch-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex-shrink: 0;
}

.switch-left .form-label {
  margin-bottom: 0;
}

/* 时间选择器横向布局 */
.time-slots {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 12rpx;
}

.time-slot-item {
  background: #FAFBFC;
  border-radius: 8rpx;
  padding: 16rpx;
  border: 1rpx solid #F0F0F0;
}

.time-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.time-col {
  flex: 1;
}

.time-col-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
}

.time-picker {
  background: #F5F7FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 76rpx;
  box-sizing: border-box;
}

.time-text {
  font-size: 28rpx;
  color: #333;
}

.next-day-tag {
  font-size: 20rpx;
  color: #4A90D9;
  background: #E8F4FD;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

.time-action,
.time-action-placeholder {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-left: 8rpx;
}

.time-action-placeholder {
  visibility: hidden;
}

.add-action {
  background: #E8F4FD;
}

.add-btn {
  font-size: 40rpx;
  color: #4A90D9;
  line-height: 1;
  font-weight: 300;
}

.remove-btn {
  font-size: 36rpx;
  color: #E74C3C;
  line-height: 1;
}

/* 时间选择弹窗 */
.time-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.time-modal {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.time-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #F7F7F7;
  border-bottom: 1rpx solid #E5E5E5;
}

.time-modal-btn {
  font-size: 28rpx;
  color: #4A90D9;
  padding: 0 16rpx;
}

.time-modal-btn.cancel {
  color: #999;
}

.time-modal-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 今日/次日切换 */
.day-toggle {
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0F0F0;
}

.day-option {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F7FA;
  transition: all 0.2s;
  margin: 0 6rpx;
}

.day-option.active {
  background: #4A90D9;
  color: #fff;
}

/* 时间选择器 */
.time-selector {
  height: 440rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.time-selector picker-view {
  height: 100%;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
}

.picker {
  background: #F5F7FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.color-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-item {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.color-item.active {
  border-color: #333;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
}

.preview-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #F0F0F0;
}

.preview-box {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.preview-tag {
  padding: 6rpx 14rpx;
  margin-right: 16rpx;
}

.preview-code {
  font-size: 32rpx;
  font-weight: bold;
}

.preview-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preview-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.preview-times {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.preview-time {
  font-size: 22rpx;
  color: #666;
  background: #fff;
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
}

.submit-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100% !important;
  height: 110rpx;
  line-height: 110rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
  border-radius: 0;
  padding: 0 !important;
  margin: 0;
  box-shadow: 0 -4rpx 20rpx rgba(74, 144, 217, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.submit-btn::before {
  display: none;
}

.submit-btn::after {
  display: none;
  border: none;
}

.submit-btn[disabled] {
  background: #B8B8B8;
  color: #666;
  box-shadow: none;
  width: 100% !important;
}

.submit-btn:not([disabled]):active {
  background: linear-gradient(135deg, #357ABD 0%, #2868A8 100%);
}
