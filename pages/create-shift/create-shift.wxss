/* pages/create-shift/create-shift.wxss */

page {
  background: #E8F0FE;
}

.create-shift-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F0FE 0%, #F5F7FA 30%);
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* 表单卡片 */
.form-card {
  margin: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #4A90D9;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.section-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

/* 表单组 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.label-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #4A90D9;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.form-label-sub {
  font-size: 24rpx;
  color: #AAA;
  margin-left: 12rpx;
}

/* 输入框 */
.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.form-input {
  width: 100%;
  height: 92rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s;
}

.form-input:focus {
  background: #F0F4FF;
}

.input-placeholder {
  color: #C8C8C8;
  font-size: 28rpx;
}

.input-count {
  position: absolute;
  right: 24rpx;
  font-size: 22rpx;
  color: #C8C8C8;
}

/* 编号输入框带预览徽章 */
.input-code-wrapper .form-input {
  padding-right: 120rpx;
}

.code-preview-badge {
  position: absolute;
  right: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 6rpx 20rpx;
  border-radius: 10rpx;
}

/* 分割线 */
.form-divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 32rpx 0;
}

/* 时间段卡片 */
.time-slots {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.time-slot-card {
  background: #FAFBFC;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.time-slot-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.time-slot-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.time-slot-actions {
  display: flex;
  gap: 16rpx;
}

.time-action-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.time-action-btn.add-btn {
  background: #E8F4FD;
}

.time-action-btn.remove-btn {
  background: #FDE8E8;
}

.action-icon {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.add-icon {
  color: #4A90D9;
}

.remove-icon {
  color: #E74C3C;
}

.action-text {
  font-size: 22rpx;
}

.add-btn .action-text {
  color: #4A90D9;
}

.remove-btn .action-text {
  color: #E74C3C;
}

/* 时间选择行 */
.time-slot-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.time-picker-card {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.time-picker-label {
  font-size: 22rpx;
  color: #BBB;
  margin-right: 4rpx;
}

.time-picker-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  flex: 1;
}

.next-day-badge {
  font-size: 20rpx;
  color: #4A90D9;
  background: #E8F4FD;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.time-arrow {
  flex-shrink: 0;
  padding: 0 4rpx;
}

.arrow-line {
  font-size: 28rpx;
  color: #CCC;
}

/* 行内表单（时长+系数） */
.inline-form-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 0;
}

.inline-form-item {
  flex: 1;
}

.inline-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 14rpx;
  display: block;
}

.inline-input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.inline-input {
  width: 100%;
  height: 92rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 0 80rpx 0 28rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  transition: all 0.2s;
}

.inline-input:focus {
  background: #F0F4FF;
}

.inline-unit {
  position: absolute;
  right: 24rpx;
  font-size: 26rpx;
  color: #999;
}

/* 开关行 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0 32rpx;
}

.switch-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.switch-desc {
  font-size: 24rpx;
  color: #AAA;
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 8rpx 0;
}

.color-item {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.color-item.active {
  border-color: #333;
  transform: scale(1.15);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.color-check {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 预览 */
.preview-section {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #F0F0F0;
}

.preview-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

.preview-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FAFBFC;
  border-radius: 16rpx;
}

.preview-badge {
  font-size: 36rpx;
  font-weight: 800;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.preview-detail {
  flex: 1;
  min-width: 0;
}

.preview-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.preview-times {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.preview-time {
  font-size: 22rpx;
  color: #888;
  background: #fff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.preview-duration {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.duration-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A90D9;
}

.duration-unit {
  font-size: 22rpx;
  color: #4A90D9;
  font-weight: 500;
}

/* 底部提交按钮 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.submit-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  border: none;
  border-radius: 48rpx !important;
  padding: 0 !important;
  margin: 0;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.submit-btn::before {
  display: none;
}

.submit-btn::after {
  display: none;
  border: none;
}

.submit-btn[disabled] {
  background: #D9D9D9;
  color: #fff;
  box-shadow: none;
}

.submit-btn:not([disabled]):active {
  background: linear-gradient(135deg, #357ABD 0%, #2868A8 100%);
  transform: scale(0.98);
}

/* 时间选择弹窗 */
.time-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.time-modal {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.time-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.time-modal-cancel {
  font-size: 28rpx;
  color: #999;
}

.time-modal-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.time-modal-confirm {
  font-size: 28rpx;
  color: #4A90D9;
  font-weight: 600;
}

/* 今日/次日切换 */
.day-toggle {
  display: flex;
  padding: 20rpx 36rpx;
  gap: 12rpx;
}

.day-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F7FA;
  transition: all 0.2s;
  font-weight: 500;
}

.day-option.active {
  background: #4A90D9;
  color: #fff;
}

/* 时间选择器 */
.time-selector {
  height: 440rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.time-selector picker-view {
  height: 100%;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
}
