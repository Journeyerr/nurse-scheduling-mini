/* pages/schedule-apply/schedule-apply.wxss */

.apply-container {
  min-height: 100vh;
  background: #F0F4F8;
  padding-bottom: 40rpx;
}

/* ==================== 主体区域 ==================== */
.section {
  margin: 24rpx;
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-dot {
  width: 8rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #4A90D9, #6AA8E8);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A2B4A;
}

.btn-add {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
}

.btn-add:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-add-icon {
  width: 80rpx;
  height: 50rpx;
}

/* ==================== 申请列表 ==================== */
.apply-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.apply-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.apply-item.processed {
  opacity: 0.55;
}

.apply-item-inner {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
}

/* 内容区 */
.apply-content {
  flex: 1;
  min-width: 0;
}

.apply-row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.apply-row-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 内联类型标签 */
.apply-type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.apply-type-tag.schedule {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  color: #1976D2;
}

.apply-type-tag.swap {
  background: linear-gradient(135deg, #F3E5F5, #E1BEE7);
  color: #9848DA;
}

.apply-row-time {
  display: flex;
  justify-content: flex-end;
  margin-top: 8rpx;
}

.time-text {
  font-size: 20rpx;
  color: #B8C4D0;
}

.apply-user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2B4A;
}

/* 右侧状态 */
.apply-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.apply-status.pending {
  color: #F5A623;
  background: #FFF8E1;
}

.apply-status.approved {
  color: #43A047;
  background: #E8F5E9;
}

.apply-status.rejected {
  color: #E74C3C;
  background: #FFEBEE;
}

.apply-status.cancelled {
  color: #8A9EB5;
  background: #F0F4F8;
}

/* 信息行 */
.apply-row-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
}

.info-text {
  font-size: 24rpx;
  color: #5A6A80;
}

.info-highlight {
  font-weight: 600;
}

.info-sep {
  font-size: 20rpx;
  color: #D0D6DE;
  margin: 0 2rpx;
}

.info-swap-icon {
  font-size: 22rpx;
  color: #4A90D9;
  margin: 0 4rpx;
}

/* 换班卡片信息网格 */
.swap-info-grid {
  display: flex;
  align-items: center;
  line-height: 1.4;
}

.swap-info-left {
  width: 120rpx;
  font-size: 24rpx;
  color: #5A6A80;
  flex-shrink: 0;
  /* text-align: center; */
}

.swap-info-arrow {
  width: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: #4A90D9;
  flex-shrink: 0;
}

.swap-info-arrow-img {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.swap-info-right {
  font-size: 24rpx;
  color: #5A6A80;
}

.apply-row-sub {
  margin-top: 4rpx;
}

.sub-text {
  font-size: 22rpx;
  color: #8A9EB5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 50rpx 60rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: #F0F4F8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-emoji {
  font-size: 52rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #5A6A80;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #A0AEBF;
}

/* ==================== 加载更多 ==================== */
.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0 16rpx;
}

.load-more-loading {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.load-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #D0D6DE;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.load-more-text {
  font-size: 24rpx;
  color: #A0AEBF;
}

/* ==================== 弹窗通用 ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.bottom-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.modal-mask.show .bottom-modal {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #F0F2F5;
  flex-shrink: 0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A2B4A;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F5F7FA;
}

.close-icon {
  font-size: 36rpx;
  color: #7A8A9E;
  line-height: 1;
}

.modal-scroll {
  flex: 1;
  overflow-y: auto;
}

.modal-body-inner {
  padding: 28rpx 32rpx;
}

.modal-footer {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
  flex-shrink: 0;
}

/* ==================== 申请类型选择 ==================== */
.type-option {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-option:last-child {
  margin-bottom: 0;
}

.type-option:active {
  background: #EAF2FC;
  border-color: #4A90D9;
}

.type-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.schedule-type-icon {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  color: #1976D2;
}

.swap-type-icon {
  background: linear-gradient(135deg, #F3E5F5, #E1BEE7);
  color: #9848DA;
}

.type-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.type-name {
  font-size: 30rpx;
  color: #1A2B4A;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.type-desc {
  font-size: 24rpx;
  color: #8A9EB5;
}

.type-arrow {
  font-size: 32rpx;
  color: #B8C4D0;
}

/* ==================== 详情弹窗 ==================== */
.detail-status-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.detail-status-banner.pending {
  background: #FFF8E1;
}

.detail-status-banner.approved {
  background: #E8F5E9;
}

.detail-status-banner.rejected {
  background: #FFEBEE;
}

.detail-status-banner.cancelled {
  background: #F0F4F8;
}

.detail-status-icon {
  font-size: 32rpx;
}

.detail-status-text {
  font-size: 30rpx;
  font-weight: 600;
}

.detail-status-banner.pending .detail-status-text {
  color: #F5A623;
}

.detail-status-banner.approved .detail-status-text {
  color: #43A047;
}

.detail-status-banner.rejected .detail-status-text {
  color: #E74C3C;
}

.detail-status-banner.cancelled .detail-status-text {
  color: #8A9EB5;
}

.detail-card {
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 12rpx 0;
}

.detail-row-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
}

.detail-row-icon-img {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-right: 4rpx;
}

.detail-row-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.detail-row-label {
  font-size: 24rpx;
  color: #8A9EB5;
}

.detail-row-value {
  font-size: 28rpx;
  color: #2C3E50;
  font-weight: 500;
}

.detail-divider {
  height: 1rpx;
  background: #E4E9F0;
  margin: 4rpx 0;
}

/* 换班详情块 */
.swap-detail-block {
  flex: 1;
  min-width: 0;
}

.swap-detail-label {
  font-size: 22rpx;
  color: #8A9EB5;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.swap-detail-items {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.swap-detail-item {
  display: flex;
  align-items: center;
}

.swap-detail-key {
  font-size: 24rpx;
  color: #8A9EB5;
  width: 80rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.swap-detail-val {
  font-size: 26rpx;
  color: #595969;
  font-weight: 500;
}

.swap-detail-center {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
}

.swap-detail-arrow {
  font-size: 32rpx;
  color: #4A90D9;
}

/* ==================== 表单样式 ==================== */
.form-group {
  margin-bottom: 32rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.label-dot {
  width: 6rpx;
  height: 24rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #4A90D9, #6AA8E8);
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

/* 选择器卡片 */
.picker-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
}

.picker-card.placeholder .picker-value {
  color: #B8C4D0;
}

.picker-value {
  font-size: 28rpx;
  color: #2C3E50;
  font-weight: 500;
}

.picker-arrow {
  font-size: 32rpx;
  color: #B8C4D0;
}

/* 换班选择行 */
.swap-picker-row {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
}

.swap-picker-row picker {
  flex: 1;
  min-width: 0;
}

.swap-picker-card {
  flex: 1;
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.swap-picker-card.disabled {
  opacity: 0.5;
}

.swap-picker-card.placeholder .swap-picker-value {
  color: #B8C4D0;
}

.swap-picker-label {
  font-size: 22rpx;
  color: #8A9EB5;
  font-weight: 600;
}

.swap-picker-value {
  font-size: 26rpx;
  color: #2C3E50;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.swap-center-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4rpx;
  flex-shrink: 0;
  color: #4A90D9;
  font-size: 32rpx;
}

/* 文本域 */
.textarea {
  width: 100%;
  min-height: 80rpx;
  padding: 22rpx 20rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #2C3E50;
  box-sizing: border-box;
  line-height: 1.5;
}

.textarea-placeholder {
  color: #B8C4D0;
}

/* ==================== 班种标签 ==================== */
.shift-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.shift-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.shift-tag:active {
  transform: scale(0.97);
}

.shift-tag.active {
  background: #fff;
  border-color: #4A90D9;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.2);
}

.shift-tag-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.shift-tag-text {
  font-size: 26rpx;
  color: #2C3E50;
  font-weight: 500;
  white-space: nowrap;
}

/* ==================== 提交按钮 ==================== */
.btn-submit-form {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  border: none;
  border-radius: 48rpx !important;
  padding: 0 !important;
  margin: 0;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.btn-submit-form::before {
  display: none;
}

.btn-submit-form::after {
  display: none;
  border: none;
}

.btn-submit-form:active {
  background: linear-gradient(135deg, #357ABD 0%, #2868A8 100%);
  transform: scale(0.98);
}

/* ==================== 弹窗高度 ==================== */
.detail-modal {
  max-height: 75vh;
}

/* ==================== 取消申请按钮 ==================== */
.cancel-actions {
  margin-top: 24rpx;
}

.btn-cancel-apply {
  width: 100% !important;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #E74C3C;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  border: 2rpx solid #E74C3C;
  border-radius: 44rpx !important;
  padding: 0 !important;
  margin: 0;
  transition: all 0.2s;
}

.btn-cancel-apply::before {
  display: none;
}

.btn-cancel-apply::after {
  display: none;
  border: none;
}

.btn-cancel-apply:active {
  background: #FFEBEE;
  transform: scale(0.98);
}

.swap-modal {
  max-height: 85vh;
}

.edit-modal {
  max-height: 85vh;
}
