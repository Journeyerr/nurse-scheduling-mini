<!--pages/index/index.wxml-->

<!-- 启动加载提示 -->
<view class="launch-loading" wx:if="{{isLaunching}}">
  <view class="loading-content">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载...</text>
  </view>
</view>

<view class="index-container" wx:else>
  <!-- 顶部错误提示条 -->
  <view class="error-bar" wx:if="{{showErrorBar}}">
    <text class="error-text">{{errorMessage}}</text>
  </view>

  <!-- 核心日历区 -->
  <view class="calendar-section card">
    <!-- 月份切换 -->
    <view class="calendar-header">
      <view class="month-nav" bindtap="prevMonth">
        <text class="nav-arrow">‹</text>
      </view>
      <text class="current-month">{{currentYear}}年{{currentMonth}}月</text>
      <view class="month-nav" bindtap="nextMonth">
        <text class="nav-arrow">›</text>
      </view>
    </view>

    <!-- 星期标题 -->
    <view class="week-header">
      <text class="week-item" wx:for="{{weekDays}}" wx:key="*this">{{item}}</text>
    </view>

    <!-- 日历网格 -->
    <swiper class="calendar-swiper" style="height: {{calendarHeight}}rpx" current="{{swiperIndex}}" bindchange="onSwiperChange">
      <swiper-item wx:for="{{calendarList}}" wx:key="index">
        <view class="calendar-grid">
          <view class="week-row" wx:for="{{item}}" wx:for-item="week" wx:key="index">
            <view
              class="day-cell {{day.isToday ? 'today' : ''}} {{!day.isCurrentMonth ? 'other-month' : ''}}"
              wx:for="{{week}}"
              wx:for-item="day"
              wx:key="date"
              bindtap="onDayTap"
              data-date="{{day.date}}"
              data-day="{{day.day}}"
            >
              <view class="day-number-wrapper">
                <text class="day-number" wx:if="{{day.day}}">{{day.day}}</text>
              </view>
              <!-- 显示排班编码 -->
              <text class="schedule-code" style="color: {{day.scheduleColor}}" wx:if="{{day.scheduleCode}}">{{day.scheduleCode}}</text>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 功能按钮区 -->
  <view class="action-section card">
    <view class="action-grid">
      <!-- 护士长可见 -->
      <view class="action-item" wx:if="{{isLeader}}" bindtap="goSchedule">
        <view class="item-icon schedule-icon">
          <text class="icon-text">排</text>
        </view>
        <text class="item-name">排班</text>
      </view>
      <view class="action-item" wx:if="{{isLeader}}" bindtap="goShiftManage">
        <view class="item-icon shift-icon">
          <text class="icon-text">班</text>
        </view>
        <text class="item-name">班种</text>
      </view>
      <view class="action-item" wx:if="{{isLeader}}" bindtap="goPrint">
        <view class="item-icon print-icon">
          <text class="icon-text">统</text>
        </view>
        <text class="item-name">统计</text>
      </view>
      <view class="action-item" wx:if="{{isLeader}}" bindtap="goApproval">
        <view class="item-icon approval-icon">
          <text class="icon-text">审</text>
        </view>
        <text class="item-name">审批</text>
        <view class="badge" wx:if="{{pendingCount > 0}}">{{pendingCount}}</view>
      </view>
      <!-- 全员可见 -->
      <view class="action-item" bindtap="goStatistics">
        <view class="item-icon stats-icon">
          <text class="icon-text">时</text>
        </view>
        <text class="item-name">工时</text>
      </view>
      <view class="action-item" bindtap="goExpectSchedule">
        <view class="item-icon expect-icon">
          <text class="icon-text">申</text>
        </view>
        <text class="item-name">申请</text>
      </view>
      <view class="action-item" bindtap="goTeamSchedule">
        <view class="item-icon team-icon">
          <text class="icon-text">全</text>
        </view>
        <text class="item-name">全科</text>
      </view>
      <!-- <view class="action-item" bindtap="goLeaveApply">
        <view class="item-icon leave-icon">
          <text class="icon-text">假</text>
        </view>
        <text class="item-name">假勤申请</text>
      </view> -->
    </view>
  </view>

  <!-- 科室信息与邀请（护士长可见） -->
  <view class="invite-section card" wx:if="{{isCreator}}">
    <view class="dept-info-row">
      <view class="dept-info-left" bindtap="showDepartmentActions" hover-class="invite-text-hover">
        <text class="dept-name-text">{{department.name}}</text>
        <image class="search-icon-inline" src="/assets/icons/search.png" catchtap="toggleSearch" mode="aspectFit"></image>
      </view>
      <button class="invite-btn-new" size="mini" open-type="share">
        <text class="invite-link-text">邀请成员</text>
        <image class="invite-arrow-img" src="/assets/images/arrow-right.png" mode="aspectFit"></image>
      </button>
    </view>
  </view>

  <!-- 科室信息（非护士长成员可见） -->
  <view class="invite-section card" wx:if="{{hasDepartment && !isCreator}}">
    <view class="dept-info-row">
      <view class="dept-info-left" bindtap="showMemberActions" hover-class="invite-text-hover">
        <text class="dept-name-text">{{department.name}}</text>
        <image class="search-icon-inline" src="/assets/icons/search.png" catchtap="toggleSearch" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <!-- 成员列表区（搜索时隐藏） -->
  <view class="member-section card" wx:if="{{hasDepartment && !showSearchInput && filteredMembers.length > 0}}">
    <view class="member-list">
      <view 
        class="member-item" 
        wx:for="{{displayMembers}}" 
        wx:key="id"
        bindtap="goMemberInfo"
        data-id="{{item.id}}"
      >
        <view class="member-left">
          <view 
            class="member-avatar-text" 
            wx:if="{{!item.avatarUrl}}"
            catchtap="onAvatarTap"
            data-id="{{item.id}}"
            data-phone="{{item.phone}}"
            data-isself="{{item.isSelf}}"
          >
            <text>{{item.nickName[0]}}</text>
          </view>
          <image 
            class="member-avatar" 
            src="{{item.avatarUrl}}" 
            mode="aspectFill" 
            wx:else
            catchtap="onAvatarTap"
            data-id="{{item.id}}"
            data-phone="{{item.phone}}"
            data-isself="{{item.isSelf}}"
          ></image>
          <view class="member-info">
            <view class="member-name-row">
              <text class="member-name">{{item.nickName}}</text>
              <view class="tag tag-self" wx:if="{{item.isSelf}}">我</view>
              <view class="tag tag-creator" wx:if="{{item.isCreator}}">创建者</view>
            </view>
          </view>
        </view>
        <text class="member-arrow">›</text>
      </view>
    </view>
    <!-- 底部操作栏：展开/收起 -->
    <view class="member-toggle" wx:if="{{filteredMembers.length > 3}}" bindtap="toggleMemberList">
      <text class="member-toggle-text">{{memberExpanded ? '收起' : '展开更多（共' + filteredMembers.length + '人）'}}</text>
      <text class="member-toggle-arrow {{memberExpanded ? 'arrow-up' : 'arrow-down'}}">›</text>
    </view>
    <view class="member-toggle" wx:elif="{{filteredMembers.length <= 3 && filteredMembers.length > 0}}">
      <text class="member-toggle-text">共{{filteredMembers.length}}人</text>
    </view>
  </view>

  <!-- 搜索弹窗 -->
  <view class="search-mask" wx:if="{{showSearchInput}}" catchtouchmove="stopPropagation">
    <view class="search-header">
      <input 
        class="search-mask-input" 
        placeholder="搜索成员姓名" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        focus="{{showSearchInput}}"
        adjust-position="{{true}}"
      />
      <text class="search-mask-close" bindtap="closeSearch">取消</text>
    </view>
    <scroll-view scroll-y class="search-result-list">
      <view 
        class="member-item" 
        wx:for="{{filteredMembers}}" 
        wx:key="id"
        bindtap="goMemberInfo"
        data-id="{{item.id}}"
      >
        <view class="member-left">
          <view class="member-avatar-text" wx:if="{{!item.avatarUrl}}">
            <text>{{item.nickName[0]}}</text>
          </view>
          <image class="member-avatar" src="{{item.avatarUrl}}" mode="aspectFill" wx:else></image>
          <view class="member-info">
            <view class="member-name-row">
              <text class="member-name">{{item.nickName}}</text>
              <view class="tag tag-self" wx:if="{{item.isSelf}}">我</view>
              <view class="tag tag-creator" wx:if="{{item.isCreator}}">创建者</view>
            </view>
          </view>
        </view>
        <text class="member-arrow">›</text>
      </view>
      <view class="no-result" wx:if="{{searchKeyword && filteredMembers.length === 0}}">
        <text class="no-result-text">未找到匹配的成员</text>
      </view>
    </scroll-view>
  </view>

  <!-- 无科室时的底部操作区 -->
  <view class="no-department-footer" wx:if="{{!hasDepartment}}">
    <!-- 护士长角色：创建科室 + 切换为护士 -->
    <block wx:if="{{role === 'leader'}}">
      <view class="footer-action" bindtap="goCreateDepartment" hover-class="footer-action-hover">
        <view class="action-left">
          <image class="action-icon-img" src="/assets/images/create-dept.png" mode="aspectFit"></image>
          <text class="action-text">创建我的科室</text>
        </view>
        <view class="action-arrow">
          <text>去创建</text>
          <image class="arrow-icon" src="/assets/images/arrow-right.png" mode="aspectFit"></image>
        </view>
      </view>
      <view class="switch-role" bindtap="switchToNurse">
        <text class="switch-role-text">切换为护士</text>
        <text class="switch-arrow">⇄</text>
      </view>
    </block>
    <!-- 护士角色：分享给护士长 + 切换为护士长 -->
    <block wx:else>
      <button class="footer-action-btn" open-type="share" hover-class="footer-action-hover">
        <view class="action-left">
          <image class="action-icon-img" src="/assets/images/share-leader.png" mode="aspectFit"></image>
          <text class="action-text">分享给护士长</text>
        </view>
        <view class="action-arrow">
          <text>去分享</text>
          <image class="arrow-icon" src="/assets/images/arrow-right.png" mode="aspectFit"></image>
        </view>
      </button>
      <view class="switch-role" bindtap="switchToLeader">
        <text class="switch-role-text">切换为护士长</text>
        <text class="switch-arrow">⇄</text>
      </view>
    </block>
  </view>
</view>

<!-- 日期详情弹窗 -->
<view class="modal-mask" wx:if="{{showDayModal}}" bindtap="closeDayModal">
  <view class="modal-content day-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">{{selectedDate}}</text>
      <view class="modal-close" bindtap="closeDayModal">×</view>
    </view>
    <view class="modal-body">
      <view wx:if="{{daySchedule.length === 0}}" class="empty-state">
        <text>暂无排班</text>
      </view>
      <view wx:else class="schedule-list">
        <view class="schedule-item" wx:for="{{daySchedule}}" wx:key="id">
          <view class="schedule-color" style="background-color: {{item.color}}"></view>
          <view class="schedule-detail">
            <text class="schedule-name">{{item.name}}</text>
            <view class="schedule-time-row">
              <block wx:for="{{item.timeSlots || []}}" wx:for-item="slot" wx:key="index">
                <text class="schedule-time-text" wx:if="{{index > 0}}"> / </text>
                <text class="schedule-time-text">
                  {{slot.startTime}}{{slot.startIsNextDay ? '次日' : ''}}-{{slot.endTime}}{{slot.endIsNextDay ? '次日' : ''}}
                </text>
              </block>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 邀请护士长弹窗 -->
<view class="modal-mask" wx:if="{{showInviteModal}}" bindtap="closeInviteModal">
  <view class="invite-modal" catchtap="stopPropagation">
    <view class="invite-modal-title">邀请护士长</view>
    <view class="invite-modal-content">邀请护士长创建科室，加入后即可使用排班功能</view>
    <view class="invite-modal-actions">
      <button class="invite-cancel" bindtap="closeInviteModal">取消</button>
      <button class="invite-confirm" open-type="share">邀请</button>
    </view>
  </view>
</view>

<!-- 成员选择器弹窗 -->
<view class="modal-mask" wx:if="{{showMemberPicker}}" bindtap="onPickerCancel">
  <view class="picker-modal" catchtap="stopPropagation">
    <view class="picker-modal-title">{{pickerMode === 'transfer' ? '选择转让对象' : '选择移除成员'}}</view>
    <picker-view class="picker-view" value="{{[pickerIndex]}}" bindchange="onPickerChange" indicator-style="height: 80rpx;">
      <picker-view-column>
        <view class="picker-item" wx:for="{{pickerMembers}}" wx:key="id">{{item.nickName || '未命名用户'}}</view>
      </picker-view-column>
    </picker-view>
    <view class="picker-modal-actions">
      <view class="picker-btn picker-cancel" bindtap="onPickerCancel">取消</view>
      <view class="picker-btn picker-confirm" bindtap="onPickerConfirm">确定</view>
    </view>
  </view>
</view>
