/* pages/index/index.wxss */

/* 启动加载提示 */
.launch-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5E5E5;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.index-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 30rpx;
}

/* 顶部错误提示条 */
.error-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #f85b5b;
  color: #fff;
  padding: 15rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    transform: translateY(-100%);
  }
  to {
    transform: translateY(0);
  }
}

.error-text {
  font-size: 26rpx;
  text-align: center;
}

/* 顶部科室信息区 */
.header {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  padding: 40rpx 30rpx;
}

.department-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.department-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.member-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 日历区域 */
.calendar-section {
  margin: 20rpx 20rpx;
  padding: 0rpx 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.month-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow {
  font-size: 48rpx;
  color: #4A90D9;
}

.current-month {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.week-header {
  display: flex;
  margin-bottom: 10rpx;
  padding: 0;
}

.week-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

.calendar-swiper {
  min-height: 500rpx;
}

.calendar-grid {
  padding: 0;
}

.week-row {
  display: flex;
  margin-bottom: 8rpx;
}

.day-cell {
  flex: 1;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 6rpx;
  position: relative;
  box-sizing: border-box;
}

.day-number-wrapper {
  height: 44rpx;
  width: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-number {
  font-size: 30rpx;
  color: #666;
  line-height: 1;
  font-weight: 500;
}

.day-cell.other-month .day-number {
  color: #CCC;
}

/* 法定假日样式 */
.day-cell.holiday .day-number {
  color: #E8380D;
}

.day-cell.holiday.other-month {
}

.day-cell.holiday.other-month .day-number {
  color: #F5A090;
}

/* 假日标识 - 显示在日期数字右上角 */
.day-number-wrapper {
  position: relative;
}

.holiday-badge {
  position: absolute;
  top: -6rpx;
  right: -14rpx;
  font-size: 14rpx;
  color: #fff;
  background: #E8380D;
  border-radius: 4rpx;
  padding: 2rpx 4rpx;
  line-height: 1;
  font-weight: normal;
  transform: scale(0.85);
  transform-origin: left top;
}

.day-cell.holiday.other-month .holiday-badge {
  background: #F5A090;
}

/* 调休工作日样式 */
.day-cell.workday .day-number {
  color: #333;
}

.day-cell.workday {
  position: relative;
}

.workday-badge {
  position: absolute;
  top: -6rpx;
  right: -14rpx;
  font-size: 14rpx;
  color: #adb1b4;
  transform: scale(0.85);
  transform-origin: left top;
  font-weight: bold;
}

.day-cell.workday.other-month .workday-badge {
  color: #A0C4E8;
}

.day-cell.today .day-number-wrapper {
  background: #4A90D9;
  border-radius: 50%;
}

.day-cell.today .day-number {
  color: #fff;
  font-weight: bold;
}

.day-cell.today.other-month .day-number-wrapper {
  background: #CCC;
}

.schedule-code {
  font-size: 24rpx;
  font-weight: bold;
  margin-top: 2rpx;
  line-height: 1;
}

/* 功能按钮区 */
.action-section {
  margin: 20rpx;
  padding: 30rpx;
}

.action-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
}

.action-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  position: relative;
}

.item-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  background: transparent;
}

.icon-text {
  font-size: 36rpx;
  color: #4A90D9;
}

.menu-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.item-name {
  font-size: 26rpx;
  color: #666;
}

.badge {
  position: absolute;
  top: -5rpx;
  right: 20rpx;
  background: #E74C3C;
  color: #fff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

/* 邀请按钮区 */
.invite-section {
  margin: 20rpx;
  padding: 24rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
}

.dept-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dept-info-left {
  display: flex;
  align-items: center;
}

.dept-name-icon {
  padding-top: 5rpx;
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.dept-name-text {
  font-size: 31rpx;
  font-weight: bold;
  color: #333;
}

.dept-name-link {
  color: #4A90D9;
}

.dept-arrow-img {
  width: 24rpx;
  height: 24rpx;
  margin-left: 6rpx;
}

.dept-separator {
  color: #ccc;
  margin-left: 15rpx;
  font-size: 28rpx;
}

.dept-arrow-icon {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
  opacity: 0.5;
}

.dept-sep {
  font-size: 28rpx;
  color: #DDD;
  margin: 0 12rpx;
}

.dept-count-text {
  font-size: 28rpx;
  color: #666;
}

.search-icon-inline {
  width: 85rpx;
  height: 36rpx;
  /* margin-left: 8rpx; */
  margin-top: 6rpx;
  opacity: 0.5;
}

.search-icon-inline:active {
  opacity: 0.8;
}

.invite-btn-new {
  display: flex;
  align-items: center;
  padding: 8rpx 0rpx 8rpx 24rpx;
  font-size: 28rpx;
  color: #4A90D9;
  background: transparent;
  border: none;
  margin: 0;
  margin-right: -30rpx;
  line-height: 1.2;
  height: 45rpx;
  overflow: visible;
  position: relative;
  /* top: 4rpx; */
}

.invite-btn-new::after {
  display: none;
}

.invite-arrow-img {
  width: 70rpx;
  height: 45rpx;
  flex-shrink: 0;
}

.invite-link-text {
  font-size: 28rpx;
  color: #4A90D9;
}

.invite-arrow {
  font-size: 32rpx;
  color: #4A90D9;
  margin-left: 4rpx;
}


/* 搜索框 */
/* 搜索弹窗 */
.search-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F5F7FA;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.search-header {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  gap: 20rpx;
}

.search-mask-input {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx 24rpx;
  border: none;
  border-radius: 36rpx;
  background: #F0F2F5;
}

.search-mask-close {
  font-size: 28rpx;
  color: #4A90D9;
  padding: 0 4rpx;
  white-space: nowrap;
}

.search-result-list {
  height: calc(100vh - 120rpx);
  padding: 0;
  background: #fff;
}

.search-result-list .member-item {
  background: #fff;
  padding: 28rpx 30rpx;
  margin: 0;
  border-bottom: 1rpx solid #F5F5F5;
  border-radius: 0;
  box-shadow: none;
}

.search-result-list .no-result {
  margin: 0;
  padding: 120rpx 0;
  text-align: center;
}

/* 无搜索结果 */
.no-result {
  margin: 20rpx;
  padding: 80rpx 0;
  text-align: center;
}

.no-result-text {
  font-size: 28rpx;
  color: #999;
}


/* 成员列表区 */
.member-section {
  margin: 20rpx;
  padding: 30rpx 0;
}

.section-header {
  padding: 0 30rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.member-list {
  display: flex;
  flex-direction: column;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-item:active {
  background: #F8F9FA;
}

.member-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.member-avatar-text {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-avatar-text text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.member-info {
  flex: 1;
}

.member-name-row {
  display: flex;
  align-items: center;
}

.member-name {
  font-size: 30rpx;
  color: #333;
  margin-right: 10rpx;
}

.member-arrow {
  font-size: 36rpx;
  color: #CCC;
}

.member-arrow-img {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-left: 8rpx;
}

.tag-self {
  background: #FFF7E6;
  color: #FA8C16;
}

.tag-creator {
  background: #E8F4FD;
  color: #4A90D9;
}

.tag-admin {
  background: #FDF6EC;
  color: #FA8C16;
}

.tag-removable {
  position: relative;
  padding-right: 24rpx;
}

.tag-removable::after {
  content: '×';
  position: absolute;
  right: 6rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 18rpx;
  line-height: 1;
  opacity: 0.6;
}

/* 空状态 */
.empty-state {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
}

/* 日期详情弹窗 */
.day-modal {
  width: 600rpx;
  max-height: 70vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  max-height: 50vh;
  overflow-y: auto;
}

/* 当天排班列表 */
.day-schedule-list {
  padding: 10rpx 0;
}

.day-schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.day-schedule-item:last-child {
  border-bottom: none;
}

.day-schedule-color {
  width: 10rpx;
  height: 40rpx;
  border-radius: 5rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.day-schedule-name {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

.day-schedule-shift {
  font-size: 26rpx;
  font-weight: 500;
}

/* 无科室底部操作区 */
.no-department-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-action {
  width: 100%;
  height: 100rpx;
  background: #fff;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 55rpx 30rpx;
  box-sizing: border-box;
  margin-top: 2rpx;
}

.footer-action-btn {
  width: 100% !important;
  height: 100rpx;
  background: #fff;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-sizing: border-box;
  margin-top: 2rpx;
  margin-left: 0;
  margin-right: 0;
  border: none;
  border-radius: 0;
  line-height: normal;
  text-align: left;
}

.footer-action-btn::after {
  display: none;
}

.footer-action-hover {
  background: #F5F5F5;
}

.action-left {
  display: flex;
  align-items: center;
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.action-icon-img {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.action-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.action-arrow {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #999;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  margin-left: 8rpx;
}

.switch-role {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  background: #F0F6FF;
  border-radius: 80rpx;
  border: 2rpx solid #4A90D9;
  margin: 60rpx 40rpx 0;
  width: calc(100% - 0rpx);
  box-sizing: border-box;
}

.switch-role-text {
  font-size: 28rpx;
  color: #4A90D9;
  margin-right: 8rpx;
  font-weight: 600;
}

.switch-arrow {
  font-size: 28rpx;
  color: #4A90D9;
}

/* 邀请护士长弹窗 */
.invite-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 1001;
}

.invite-modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  padding: 40rpx 30rpx 20rpx;
}

.invite-modal-content {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  padding: 0 30rpx 40rpx;
}

.invite-modal-actions {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.invite-cancel, .invite-confirm {
  flex: 1;
  height: 100rpx;
  font-size: 32rpx;
  border: none;
  border-radius: 0;
  line-height: 100rpx;
}

.invite-cancel {
  background: #fff;
  color: #666;
}

.invite-confirm {
  background: #4A90D9;
  color: #fff;
}

.invite-cancel::after, .invite-confirm::after {
  display: none;
}

/* 成员选择器弹窗 */
.picker-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  padding: 30rpx 0 20rpx;
}

.picker-view {
  width: 100%;
  height: 400rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-modal-actions {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.picker-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
}

.picker-cancel {
  color: #999;
}

.picker-confirm {
  color: #4A90D9;
}

/* 成员列表折叠/展开 */
.member-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-top: 1rpx solid #F5F5F5;
}

.member-toggle-text {
  font-size: 26rpx;
  color: #4A90D9;
}

.member-toggle-arrow {
  font-size: 28rpx;
  color: #4A90D9;
  margin-left: 8rpx;
  transition: transform 0.3s;
}

.member-toggle-arrow.arrow-up {
  transform: rotate(-90deg);
}

.member-toggle-arrow.arrow-down {
  transform: rotate(90deg);
}
