/* pages/index/index.wxss */

/* 启动加载提示 */
.launch-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E5E5E5;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.index-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 30rpx;
}

/* 顶部错误提示条 */
.error-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #f85b5b;
  color: #fff;
  padding: 15rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    transform: translateY(-100%);
  }
  to {
    transform: translateY(0);
  }
}

.error-text {
  font-size: 26rpx;
  text-align: center;
}

/* 顶部科室信息区 */
.header {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  padding: 40rpx 30rpx;
}

.department-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.department-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.member-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 日历区域 */
.calendar-section {
  margin: 20rpx 20rpx;
  padding: 0rpx 30rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.month-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow {
  font-size: 48rpx;
  color: #4A90D9;
}

.current-month {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.week-header {
  display: flex;
  margin-bottom: 10rpx;
  padding: 0;
}

.week-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

.calendar-swiper {
  min-height: 500rpx;
}

.calendar-grid {
  padding: 0;
}

.week-row {
  display: flex;
  margin-bottom: 8rpx;
}

.day-cell {
  flex: 1;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 6rpx;
  position: relative;
  box-sizing: border-box;
}

.day-number-wrapper {
  height: 44rpx;
  width: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-number {
  font-size: 30rpx;
  color: #333;
  line-height: 1;
  font-weight: 500;
}

.day-cell.other-month .day-number {
  color: #CCC;
}

.day-cell.today .day-number-wrapper {
  background: #4A90D9;
  border-radius: 50%;
}

.day-cell.today .day-number {
  color: #fff;
  font-weight: bold;
}

.day-cell.today.other-month .day-number-wrapper {
  background: #CCC;
}

.schedule-code {
  font-size: 24rpx;
  font-weight: bold;
  margin-top: 2rpx;
  line-height: 1;
}

/* 功能按钮区 */
.action-section {
  margin: 20rpx;
  padding: 30rpx;
}

.action-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
}

.action-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  position: relative;
}

.item-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  background: #F5F7FA;
}

.icon-text {
  font-size: 36rpx;
  color: #4A90D9;
}

.item-name {
  font-size: 26rpx;
  color: #666;
}

.badge {
  position: absolute;
  top: -5rpx;
  right: 20rpx;
  background: #E74C3C;
  color: #fff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

/* 邀请按钮区 */
.invite-section {
  margin: 20rpx;
  padding: 24rpx 20rpx 24rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
}

.dept-info-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.invite-text {
  font-size: 30rpx;
  color: #4A90D9;
}

.search-icon {
  width: 60rpx;
  height: 40rpx;
  padding: 8rpx;
  margin-left: 6rpx;
  margin-top: 9rpx;
  opacity: 0.6;
}

.invite-text-hover {
  opacity: 0.7;
}

/* 搜索框 */
.search-section {
  margin: 0 20rpx 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx 24rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 12rpx;
}

.search-close {
  font-size: 40rpx;
  color: #999;
  padding: 0 8rpx;
}

/* 无搜索结果 */
.no-result {
  margin: 20rpx;
  padding: 80rpx 0;
  text-align: center;
}

.no-result-text {
  font-size: 28rpx;
  color: #999;
}

.invite-btn {
  font-size: 30rpx;
  color: #4A90D9;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  height: auto;
  width: auto;
  min-width: 0;
  min-height: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-weight: normal;
}

.invite-btn::after {
  display: none;
}

.invite-icon {
  width: 60rpx;
  height: 40rpx;
  margin-left: 6rpx;
}

/* 成员列表区 */
.member-section {
  margin: 20rpx;
  padding: 30rpx 0;
}

.section-header {
  padding: 0 30rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.member-list {
  display: flex;
  flex-direction: column;
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-item:active {
  background: #F8F9FA;
}

.member-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.member-avatar-text {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-avatar-text text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.member-info {
  flex: 1;
}

.member-name-row {
  display: flex;
  align-items: center;
}

.member-name {
  font-size: 30rpx;
  color: #333;
  margin-right: 10rpx;
}

.member-arrow {
  font-size: 36rpx;
  color: #CCC;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-left: 8rpx;
}

.tag-self {
  background: #FFF7E6;
  color: #FA8C16;
}

.tag-creator {
  background: #E8F4FD;
  color: #4A90D9;
}

/* 空状态 */
.empty-state {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
}

/* 日期详情弹窗 */
.day-modal {
  width: 600rpx;
  max-height: 70vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  max-height: 50vh;
  overflow-y: auto;
}

.schedule-list {
  padding: 20rpx 0;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-color {
  width: 12rpx;
  height: 60rpx;
  border-radius: 6rpx;
  margin-right: 24rpx;
}

.schedule-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.schedule-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.schedule-time {
  font-size: 26rpx;
  color: #999;
}

.schedule-time-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.schedule-time-text {
  font-size: 24rpx;
  color: #999;
}

/* 无科室底部操作区 */
.no-department-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-action {
  width: 100%;
  height: 100rpx;
  background: #fff;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 55rpx 30rpx;
  box-sizing: border-box;
  margin-top: 2rpx;
}

.footer-action-btn {
  width: 100% !important;
  height: 100rpx;
  background: #fff;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-sizing: border-box;
  margin-top: 2rpx;
  margin-left: 0;
  margin-right: 0;
  border: none;
  border-radius: 0;
  line-height: normal;
  text-align: left;
}

.footer-action-btn::after {
  display: none;
}

.footer-action-hover {
  background: #F5F5F5;
}

.action-left {
  display: flex;
  align-items: center;
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.action-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.action-arrow {
  font-size: 28rpx;
  color: #999;
}

.switch-role {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 40rpx;
}

.switch-role-text {
  font-size: 30rpx;
  color: #4A90D9;
  margin-right: 8rpx;
}

.switch-arrow {
  font-size: 30rpx;
  color: #4A90D9;
}

/* 邀请护士长弹窗 */
.invite-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 1001;
}

.invite-modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  padding: 40rpx 30rpx 20rpx;
}

.invite-modal-content {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  padding: 0 30rpx 40rpx;
}

.invite-modal-actions {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.invite-cancel, .invite-confirm {
  flex: 1;
  height: 100rpx;
  font-size: 32rpx;
  border: none;
  border-radius: 0;
  line-height: 100rpx;
}

.invite-cancel {
  background: #fff;
  color: #666;
}

.invite-confirm {
  background: #4A90D9;
  color: #fff;
}

.invite-cancel::after, .invite-confirm::after {
  display: none;
}
