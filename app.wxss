/* app.wxss - 全局样式 */

/* 重置样式 */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  padding: 30rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 按钮样式 - 固定底部提交按钮 */
.btn-submit {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100% !important;
  height: 110rpx;
  line-height: 110rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: none;
  border-radius: 0;
  padding: 0 !important;
  margin: 0;
  box-shadow: 0 -4rpx 20rpx rgba(74, 144, 217, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.btn-submit::before {
  display: none;
}

.btn-submit::after {
  display: none;
  border: none;
}

.btn-submit[disabled] {
  background: #B8B8B8;
  color: #666;
  box-shadow: none;
}

.btn-submit:not([disabled]):active {
  background: linear-gradient(135deg, #357ABD 0%, #2868A8 100%);
}

/* 普通按钮样式 */
.btn-primary {
  background: #4A90D9;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 24rpx 40rpx;
  text-align: center;
}

.btn-primary:active {
  background: #3A7BC8;
}

.btn-secondary {
  background: #fff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 22rpx 38rpx;
  text-align: center;
}

.btn-danger {
  background: #E74C3C;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 24rpx 40rpx;
  text-align: center;
}

/* 输入框样式 */
.input {
  background: #F5F7FA;
  border: 2rpx solid #E8E8E8;
  border-radius: 8rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.input:focus {
  border-color: #4A90D9;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #E8E8E8;
  margin: 30rpx 0;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-left: 10rpx;
}

.tag-creator {
  background: #E8F4FD;
  color: #4A90D9;
}

.tag-leader {
  background: #FFF3E0;
  color: #F57C00;
}

/* 列表项样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0F0F0;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background: #F8F8F8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 50rpx;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  font-size: 28rpx;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

/* 弹窗内容 */
.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  width: 600rpx;
  z-index: 1001;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

/* 隐藏元素 */
.hidden {
  display: none !important;
}

/* Flex 布局辅助类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

/* 文字辅助类 */
.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-gray {
  color: #999;
}

.text-primary {
  color: #4A90D9;
}

.text-danger {
  color: #E74C3C;
}

.text-success {
  color: #27AE60;
}

/* 间距辅助类 */
.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-30 {
  margin-bottom: 30rpx;
}

.p-30 {
  padding: 30rpx;
}
